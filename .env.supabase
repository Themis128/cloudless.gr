# Supabase Local Development Environment Variables
# Copy this to .env.local for local Supabase development

# Supabase local development (these are the default local development values)
SUPABASE_URL=http://localhost:54321
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZS1kZW1vIiwicm9sZSI6ImFub24iLCJleHAiOjE5ODM4MTI5OTZ9.CRXP1A7WOeoJeXxjNni43kdQwgnWNReilDMblYTn_I0
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZS1kZW1vIiwicm9sZSI6InNlcnZpY2Vfcm9sZSIsImV4cCI6MTk4MzgxMjk5Nn0.EGIM96RAZx35lJzdJsyH-qQwv8Hdp7fsn3W0YpN81IU

# Database connection (PostgreSQL)
DATABASE_URL=postgresql://postgres:your-super-secret-and-long-postgres-password@localhost:54322/postgres

# Dashboard and Admin
DASHBOARD_USERNAME=supabase
DASHBOARD_PASSWORD=this_password_is_insecure_and_should_be_updated

# API Gateway
KONG_HTTP_PORT=8000
KONG_HTTPS_PORT=8443

# Email configuration (Inbucket for local testing)
SMTP_HOST=localhost
SMTP_PORT=54325
SMTP_USER=
SMTP_PASS=

# JWT Secret
JWT_SECRET=super-secret-jwt-token-with-at-least-32-characters-long

# Additional configuration
ENABLE_EMAIL_CONFIRMATIONS=false
ENABLE_EMAIL_AUTOCONFIRM=true
DISABLE_SIGNUP=false

# Studio configuration
STUDIO_PORT=54323
PUBLIC_REST_URL=http://localhost:54321/rest/v1/
PUBLIC_REALTIME_URL=ws://localhost:54321/realtime/v1/
PUBLIC_STORAGE_URL=http://localhost:54321/storage/v1/
