{
  "name": "cloudless-gr",
  "version": "1.0.0",
  "description": "Cloudless LLM Dev Agent - Low-code platform for data pipelines, analytics, and AI",
  "private": true,
  "scripts": {
    "build": "nuxt build",
    "dev": "nuxt dev",
    "generate": "nuxt generate",
    "preview": "nuxt preview",
    "start": "node scripts/server/start-server.js",
    "postinstall": "nuxt prepare",
    "test": "playwright test",
    "test:quick": "playwright test --grep @quick || echo 'No quick tests found'",
    "test:integration": "node test-integration.js",
    "lint": "eslint . --ext .vue,.ts,.js --max-warnings 0",
    "lint:fix": "eslint . --ext .vue,.ts,.js --fix --max-warnings 0",
    "lint:vue": "eslint . --ext .vue --max-warnings 0",
    "lint:ts": "eslint . --ext .ts --max-warnings 0",
    "lint:js": "eslint . --ext .js --max-warnings 0",
    "lint:pages": "eslint pages/ --ext .vue --max-warnings 0",
    "lint:components": "eslint components/ --ext .vue --max-warnings 0",
    "lint:server": "eslint server/ --ext .ts --max-warnings 0",
    "spell": "cspell .",
    "spell:fix": "cspell . --fix",
    "docker:dev": "bash scripts/docker/dev-docker.sh start",
    "docker:dev:start": "bash scripts/docker/dev-docker.sh start",
    "docker:dev:stop": "bash scripts/docker/dev-docker.sh stop",
    "docker:dev:restart": "bash scripts/docker/dev-docker.sh restart",
    "docker:dev:logs": "bash scripts/docker/dev-docker.sh logs",
    "docker:dev:shell": "bash scripts/docker/dev-docker.sh shell",
    "docker:dev:status": "bash scripts/docker/dev-docker.sh status",
    "docker:dev:build": "bash scripts/docker/dev-docker.sh build",
    "docker:dev:clean": "bash scripts/docker/dev-docker.sh clean",
    "docker:build": "bash scripts/version.sh",
    "docker:build:win": "powershell -ExecutionPolicy Bypass -File scripts/version.ps1",
    "docker:build:registry": "bash scripts/version.sh --registry your-registry.com",
    "docker:build:push": "bash scripts/version.sh --push",
    "docker:build:win:push": "powershell -ExecutionPolicy Bypass -File scripts/version.ps1 -Push",
    "docker:clean": "docker system prune -f && docker image prune -f",
    "docker:clean:all": "docker system prune -a -f && docker image prune -a -f",
    "dev:docker": "bash scripts/docker/dev-docker.sh start",
    "dev:docker:build": "bash scripts/docker/dev-docker.sh build",
    "dev:docker:down": "bash scripts/docker/dev-docker.sh stop",
    "dev:docker:logs": "bash scripts/docker/dev-docker.sh logs",
    "dev:docker:shell": "bash scripts/docker/dev-docker.sh shell",
    "dev:docker:restart": "bash scripts/docker/dev-docker.sh restart",
    "dev:docker:clean": "bash scripts/docker/dev-docker.sh clean",
    "dev:docker:status": "bash scripts/docker/dev-docker.sh status",
    "dev:network-info": "bash scripts/get-network-info.sh",
    "dev:debug": "docker compose -f docker-compose.dev.yml exec app-dev node --inspect=0.0.0.0:9229 .output/server/index.mjs",
    "prod:deploy": "bash scripts/deploy-production.sh deploy",
    "prod:stop": "bash scripts/deploy-production.sh stop",
    "prod:logs": "bash scripts/deploy-production.sh logs",
    "prod:status": "bash scripts/deploy-production.sh status",
    "prod:health": "bash scripts/deploy-production.sh health"
  },
  "dependencies": {
    "@mdi/font": "^7.4.47",
    "@nuxt/content": "^2.7.2",
    "@nuxt/fonts": "^0.11.3",
    "@nuxt/icon": "^1.12.0",
    "@nuxt/image": "^1.10.0",
    "@nuxt/image-edge": "^1.3.0-28493895.369b747",
    "@nuxt/scripts": "^0.11.6",
    "@nuxt/test-utils": "^3.18.0",
    "@nuxt/ui": "^2.22.0",
    "@nuxtjs/seo": "^3.0.3",
    "@pinia/nuxt": "^0.5.1",
    "@prisma/client": "^6.12.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/jsonwebtoken": "^9.0.9",
    "@unhead/vue": "^2.0.8",
    "@vueuse/core": "^13.2.0",
    "@vueuse/nuxt": "^13.1.0",
    "bcryptjs": "^3.0.2",
    "jsonwebtoken": "^9.0.2",
    "node-fetch": "^3.3.2",
    "nuxt-llms": "^0.1.2",
    "pinia": "^3.0.2",
    "three": "^0.176.0",
    "vanta": "^0.5.24",
    "vue": "^3.5.17",
    "vue-echarts": "^7.0.3",
    "vuedraggable": "^4.1.0",
    "vuetify": "^3.9.2"
  },
  "devDependencies": {
    "@nuxt/eslint-config": "^0.3.0",
    "@nuxt/image": "^1.10.0",
    "@playwright/test": "^1.54.1",
    "@types/echarts": "^4.9.22",
    "@vscode/test-electron": "^2.5.2",
    "audit-ci": "^7.0.0",
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^10.1.5",
    "eslint-plugin-vue": "^10.3.0",
    "globals": "^16.1.0",
    "happy-dom": "^17.4.7",
    "husky": "^8.0.0",
    "jsdom": "^26.1.0",
    "lighthouse": "^12.6.0",
    "lint-staged": "^15.2.2",
    "nuxt": "^3.17.3",
    "postcss": "^8.4.35",
    "prettier": "^3.5.3",
    "prisma": "^6.12.0",
    "stylelint": "^16.19.1",
    "stylelint-config-recommended": "^16.0.0",
    "stylelint-config-standard": "^38.0.0",
    "stylelint-config-standard-vue": "^1.0.0",
    "tailwindcss": "^3.4.1",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.32.1",
    "vitest": "^3.1.4"
  },
  "resolutions": {
    "postcss": "^8.4.35",
    "tailwindcss": "^3.4.1"
  },
  "lint-staged": {
    "*.{js,ts,vue}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{css,scss,html}": [
      "prettier --write"
    ]
  }
}
