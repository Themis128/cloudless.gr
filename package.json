{
  "name": "cloudless-gr",
  "version": "1.0.0",
  "description": "Cloudless LLM Dev Agent - Low-code platform for data pipelines, analytics, and AI",
  "private": true,
  "scripts": {
    "build": "nuxt build",
    "dev": "nuxt dev",
    "generate": "nuxt generate",
    "preview": "nuxt preview",
    "postinstall": "nuxt prepare",
    "test": "playwright test",
    "test:integration": "node test-integration.js",
    "docker:dev": "powershell -ExecutionPolicy Bypass -File scripts/dev-docker.ps1",
    "docker:dev:start": "powershell -ExecutionPolicy Bypass -File scripts/dev-docker.ps1 start",
    "docker:dev:stop": "powershell -ExecutionPolicy Bypass -File scripts/dev-docker.ps1 stop",
    "docker:dev:restart": "powershell -ExecutionPolicy Bypass -File scripts/dev-docker.ps1 restart",
    "docker:dev:logs": "powershell -ExecutionPolicy Bypass -File scripts/dev-docker.ps1 logs",
    "docker:dev:shell": "powershell -ExecutionPolicy Bypass -File scripts/dev-docker.ps1 shell",
    "docker:dev:status": "powershell -ExecutionPolicy Bypass -File scripts/dev-docker.ps1 status",
    "docker:build": "bash scripts/version.sh",
    "docker:build:win": "powershell -ExecutionPolicy Bypass -File scripts/version.ps1",
    "docker:build:registry": "bash scripts/version.sh --registry your-registry.com",
    "docker:build:push": "bash scripts/version.sh --push",
    "docker:build:win:push": "powershell -ExecutionPolicy Bypass -File scripts/version.ps1 -Push",
    "docker:clean": "docker system prune -f && docker image prune -f",
    "docker:clean:all": "docker system prune -a -f && docker image prune -a -f"
  },
  "dependencies": {
    "@mdi/font": "^7.4.47",
    "@nuxtjs/supabase": "^1.5.3",
    "@pinia/nuxt": "^0.11.1",
    "@supabase/supabase-js": "^2.51.0",
    "dotenv": "^17.2.0",
    "echarts": "^5.6.0",
    "nitro": "^0.0.0",
    "pinia": "^3.0.3",
    "three": "^0.178.0",
    "vanta": "^0.5.24",
    "vue": "^3.5.17",
    "vue-echarts": "^7.0.3",
    "vuedraggable": "^4.1.0",
    "vuetify": "^3.9.0-beta.1"
  },
  "devDependencies": {
    "@nuxt/eslint-config": "^0.2.0",
    "@nuxt/image": "^1.10.0",
    "@playwright/test": "^1.54.1",
    "@types/echarts": "^4.9.22",
    "@vscode/test-electron": "^2.5.2",
    "audit-ci": "^7.0.0",
    "eslint": "^8.57.0",
    "eslint-plugin-vue": "^9.21.1",
    "nuxt": "^3.17.6",
    "playwright": "^1.42.1",
    "prettier": "^3.2.5",
    "supabase": "^2.30.4"
  }
}
