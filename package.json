{
  "name": "cloudless.gr",
  "version": "1.0.0",
  "description": "my platform",
  "type": "module",
  "scripts": {
    "dev": "nuxt dev",
    "build": "nuxt build",
    "start": "nuxt start",
    "lint": "eslint . --ext .js,.ts,.vue",
    "lint:fix": "eslint . --ext .js,.ts,.vue --fix",
    "lint:core": "eslint components/ pages/ composables/ stores/ middleware/ --ext .ts,.vue",
    "lint:ts": "eslint . --ext .ts,.vue --rule '@typescript-eslint/no-unused-vars: error' --rule '@typescript-eslint/no-explicit-any: warn'",
    "lint:vue": "eslint **/*.vue --rule 'vue/no-unused-vars: error' --rule 'vue/no-mutating-props: error'",
    "lint:critical": "pwsh -File .vscode/smart-lint.ps1 critical",
    "typecheck": "nuxt typecheck",
    "typecheck:core": "tsc --noEmit --skipLibCheck --exclude 'docker/**' --exclude 'test-*' --exclude 'backup-*'",
    "typecheck:watch": "tsc --noEmit --watch",
    "check:all": "npm run lint:critical && npm run typecheck:core",
    "fix:critical": "pwsh -File .vscode/auto-fix-critical.ps1 all",
    "fix:types": "pwsh -File .vscode/auto-fix-critical.ps1 types",
    "fix:supabase": "pwsh -File .vscode/auto-fix-critical.ps1 supabase",
    "fix:composables": "pwsh -File .vscode/auto-fix-critical.ps1 composables",
    "fix:database": "pwsh -File .vscode/auto-fix-critical.ps1 database",
    "fix:preview": "pwsh -File .vscode/auto-fix-critical.ps1 all -DryRun",
    "ts:autofix": "pwsh -File .vscode/typescript-autofix.ps1 all",
    "ts:fix-imports": "pwsh -File .vscode/typescript-autofix.ps1 imports",
    "ts:fix-errors": "pwsh -File .vscode/typescript-autofix.ps1 errors",
    "ts:fix-vue": "pwsh -File .vscode/typescript-autofix.ps1 vue",
    "ts:fix-supabase": "pwsh -File .vscode/typescript-autofix.ps1 supabase",
    "ts:check": "pwsh -File .vscode/typescript-autofix.ps1 typecheck",
    "ts:preview": "pwsh -File .vscode/typescript-autofix.ps1 all -DryRun",
    "supabase:types": "supabase gen types typescript --local > types/supabase-generated.ts",
    "gen:types": "supabase gen types typescript --linked --schema public > types/supabase.ts",
    "sonar": "sonar-scanner",
    "ci:local": "npm run check:all && npm run build",
    "cypress:report": "npx mochawesome-merge cypress/results/html/*.json | npx mochawesome-report-generator --reportDir cypress/results/html/merged",
    "db:check": "pwsh -File scripts/check-diff.ps1",
    "db:sync": "pwsh -File scripts/sync-to-cloud.ps1",
    "db:migrate": "pwsh -File scripts/create-migration.ps1",
    "db:status": "supabase migration list",
    "db:reset-local": "supabase db reset --local",
    "db:reset-cloud": "supabase db reset --linked",
    "env:local": "pwsh -File scripts/switch-env.ps1 local",
    "env:cloud": "pwsh -File scripts/switch-env.ps1 cloud",
    "test:e2e": "pwsh -File scripts/run-e2e-tests.ps1 -TestSuite all -Environment local -GenerateReport",
    "test:e2e:cypress": "pwsh -File scripts/run-e2e-tests.ps1 -TestSuite cypress -Environment local",
    "test:e2e:playwright": "pwsh -File scripts/run-e2e-tests.ps1 -TestSuite playwright -Environment local",
    "test:e2e:custom": "pwsh -File scripts/run-e2e-tests.ps1 -TestSuite custom -Environment local",
    "test:e2e:auth": "pwsh -File scripts/run-e2e-tests.ps1 -TestSuite auth -Environment local",
    "test:e2e:staging": "pwsh -File scripts/run-e2e-tests.ps1 -TestSuite all -Environment staging -GenerateReport",
    "test:e2e:ci": "pwsh -File scripts/run-e2e-tests.ps1 -TestSuite all -Environment local -Headless true -GenerateReport",
    "test:comprehensive": "pwsh -File scripts/run-comprehensive-tests.ps1 -TestSuite all -Environment local -GenerateReport",
    "test:auth": "pwsh -File scripts/run-comprehensive-tests.ps1 -TestSuite auth -Environment local",
    "test:routing": "pwsh -File scripts/run-comprehensive-tests.ps1 -TestSuite routing -Environment local",
    "test:system": "pwsh -File scripts/run-comprehensive-tests.ps1 -TestSuite system -Environment local",
    "test:integration": "pwsh -File scripts/run-comprehensive-tests.ps1 -TestSuite integration -Environment local",
    "test:comprehensive:headless": "pwsh -File scripts/run-comprehensive-tests.ps1 -TestSuite all -Environment local -Headless -GenerateReport",
    "test:comprehensive:staging": "pwsh -File scripts/run-comprehensive-tests.ps1 -TestSuite all -Environment staging -GenerateReport",
    "test:comprehensive:ci": "pwsh -File scripts/run-comprehensive-tests.ps1 -TestSuite all -Environment local -Headless -GenerateReport -VerboseOutput",
    "test:validate-setup": "pwsh -File scripts/validate-test-setup.ps1",
    "test:validate-setup:verbose": "pwsh -File scripts/validate-test-setup.ps1 -VerboseOutput",
    "test:final-login": "node test-final-login.mjs",
    "test:final-registration": "node test-final-registration.mjs",
    "test:robust-auth": "node test-robust-auth.mjs",
    "deploy:check": "pwsh -File scripts/vercel-deploy-check.ps1 -CheckOnly",
    "deploy:check:verbose": "pwsh -File scripts/vercel-deploy-check.ps1 -CheckOnly -Verbose",
    "deploy:staging": "pwsh -File scripts/vercel-deploy-check.ps1 -AutoDeploy -Environment staging",
    "deploy:production": "pwsh -File scripts/vercel-deploy-check.ps1 -AutoDeploy -Environment production",
    "deploy:production:skip-tests": "pwsh -File scripts/vercel-deploy-check.ps1 -AutoDeploy -Environment production -SkipTests",
    "env:setup": "pwsh -File scripts/setup-deployment-env.ps1 -ShowExample",
    "env:generate-secrets": "pwsh -File scripts/setup-deployment-env.ps1 -GenerateSecrets",
    "env:vercel-commands": "pwsh -File scripts/setup-deployment-env.ps1 -ExportForVercel",
    "env:production": "pwsh -File scripts/setup-deployment-env.ps1 -Environment production -GenerateSecrets -ExportForVercel",
    "deploy:quick:staging": "pwsh -File scripts/quick-deploy.ps1 -Environment staging",
    "deploy:quick:production": "pwsh -File scripts/quick-deploy.ps1 -Environment production",
    "deploy:quick:production:auto": "pwsh -File scripts/quick-deploy.ps1 -Environment production -AutoCommit",
    "playwright:install": "npx playwright install --with-deps",
    "playwright:test": "npx playwright test",
    "playwright:report": "npx playwright show-report",
    "playwright:ui": "npx playwright test --ui",
    "cypress:open": "npx cypress open",
    "cypress:run": "npx cypress run",
    "cypress:install": "npx cypress install",
    "mcp:start": "pwsh -File manage-dual-mcp.ps1 start",
    "mcp:stop": "pwsh -File manage-dual-mcp.ps1 stop",
    "mcp:status": "pwsh -File manage-dual-mcp.ps1 status",
    "mcp:restart": "pwsh -File manage-dual-mcp.ps1 restart",
    "mcp:test": "node test-mcp.mjs",
    "mcp:help": "npx @supabase/mcp-server-supabase@latest --version",
    "mcp:verify": "node verify-mcp.mjs"
  },
  "dependencies": {
    "@fortawesome/fontawesome-svg-core": "^6.7.2",
    "@fortawesome/free-brands-svg-icons": "^6.7.2",
    "@fortawesome/free-regular-svg-icons": "^6.7.2",
    "@fortawesome/free-solid-svg-icons": "^6.7.2",
    "@fortawesome/vue-fontawesome": "^3.0.8",
    "@heroicons/vue": "^2.2.0",
    "@mdi/font": "^7.4.47",
    "@mdi/js": "^7.4.47",
    "@nuxt/devtools": "latest",
    "@nuxtjs/supabase": "^1.5.3",
    "@nuxtjs/vuetify": "^0.1.1",
    "@pinia/nuxt": "^0.11.1",
    "@supa-kit/auth-ui-vue": "^0.4.3",
    "@supabase/auth-ui-shared": "^0.1.8",
    "@supabase/mcp-server-supabase": "^0.4.5",
    "@supabase/supabase-js": "^2.50.3",
    "@vite-pwa/nuxt": "^1.0.4",
    "@vueuse/core": "^13.3.0",
    "dompurify": "^3.2.6",
    "dotenv": "^16.5.0",
    "nuxt": "^3.17.5",
    "ollama": "^0.5.16",
    "pg": "^8.16.0",
    "pinia": "^3.0.3",
    "postgres": "^3.4.7",
    "three": "^0.177.0",
    "vanta": "^0.5.24",
    "vuetify": "^3.8.9"
  },
  "devDependencies": {
    "@cypress/vite-dev-server": "^6.0.3",
    "@eslint/js": "^9.29.0",
    "@nuxt/eslint-config": "^1.4.1",
    "@playwright/test": "^1.53.0",
    "@types/estree": "^1.0.8",
    "@types/node": "^24.0.10",
    "@types/phoenix": "^1.6.6",
    "@types/three": "^0.177.0",
    "@types/ws": "^8.18.1",
    "@vitest/ui": "^3.2.4",
    "@vue/test-utils": "^2.4.6",
    "cypress": "^14.4.1",
    "cypress-mochawesome-reporter": "^3.8.2",
    "eslint": "^9.28.0",
    "eslint-plugin-nuxt": "^4.0.0",
    "eslint-plugin-vue": "^9.33.0",
    "globals": "^16.2.0",
    "happy-dom": "^18.0.1",
    "jest-junit": "^16.0.0",
    "jsdom": "^26.1.0",
    "mocha-junit-reporter": "^2.2.1",
    "playwright": "^1.53.0",
    "prettier": "^3.5.3",
    "supabase": "^2.26.9",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.34.1",
    "vitest": "^3.2.4"
  }
}
