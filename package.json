{
  "name": "cloudless-gr",
  "version": "1.0.0",
  "description": "Cloudless LLM Dev Agent - Low-code platform for data pipelines, analytics, and AI",
  "private": true,
  "packageManager": "pnpm@10.13.1+sha512.37ebf1a5c7a30d5fabe0c5df44ee8da4c965ca0c5af3dbab28c3a1681b70a256218d05c81c9c0dcf767ef6b8551eb5b960042b9ed4300c59242336377e01cfad",
  "prisma": {
    "seed": "npx tsx prisma/seed.ts"
  },
  "scripts": {
    "build": "nuxt build",
    "dev": "nuxt dev",
    "dev:network": "nuxt dev --host 192.168.0.23 --port 3002",
    "dev:test": "pwsh -File .\\scripts\\Run-DevServerForTests.ps1",
    "dev:3001": "powershell -Command \"$env:NUXT_PORT='3001'; nuxt dev\"",
    "generate": "nuxt generate",
    "preview": "nuxt preview",
    "start": "node scripts/server/start-server.js",
    "postinstall": "nuxt prepare",
    "test": "playwright test",
    "test:quick": "playwright test --grep @quick || echo 'No quick tests found'",
    "test:creation": "playwright test tests/creation-flows-focused.spec.js",
    "test:creation:all": "playwright test tests/creation-flows*.spec.js",
    "test:visual": "playwright test tests/visual-test-runner.spec.js --headed",
    "test:visual:slow": "playwright test tests/visual-test-runner.spec.js --headed --timeout=60000",
    "test:visual:debug": "playwright test tests/visual-test-runner.spec.js --headed --timeout=0 --debug",
    "test:dashboard": "node tests/dashboard-server.js",
    "test:visual:system": "powershell -ExecutionPolicy Bypass -File tests/launch-visual-system.ps1",
    "test:visual:system:auto": "powershell -ExecutionPolicy Bypass -File tests/launch-visual-system.ps1 -AutoStart",
    "test:visual:system:dashboard": "powershell -ExecutionPolicy Bypass -File tests/launch-visual-system.ps1 -DashboardOnly",
    "test:errors": "powershell -ExecutionPolicy Bypass -File tests/manage-errors.ps1",
    "perf:monitor": "powershell -ExecutionPolicy Bypass -File scripts/optimize-startup.ps1 -Monitor",
    "perf:optimize": "powershell -ExecutionPolicy Bypass -File scripts/optimize-startup.ps1 -Optimize",
    "perf:cleanup": "powershell -ExecutionPolicy Bypass -File scripts/optimize-startup.ps1 -Cleanup",
    "perf:health": "curl -s http://localhost:3000/api/health | jq .",
    "perf:health:refresh": "curl -s 'http://localhost:3000/api/health?refresh=true' | jq .",
    "startup:test": "npm run perf:cleanup && npm run perf:optimize && npm run perf:monitor",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate dev",
    "db:studio": "prisma studio",
    "db:seed": "prisma db seed",
    "db:reset": "prisma migrate reset --force",
    "db:backup": "powershell -ExecutionPolicy Bypass -File scripts/utils/backup-database.ps1",
    "docker:dev": "docker compose -f docker-compose.dev.yml up -d",
    "docker:dev:build": "docker compose -f docker-compose.dev.yml up -d --build",
    "docker:dev:down": "docker compose -f docker-compose.dev.yml down",
    "docker:dev:logs": "docker compose -f docker-compose.dev.yml logs -f",
    "docker:prod": "docker compose -f docker-compose.prod.yml up -d",
    "docker:prod:build": "docker compose -f docker-compose.prod.yml up -d --build",
    "docker:prod:down": "docker compose -f docker-compose.prod.yml down",
    "docker:prod:logs": "docker compose -f docker-compose.prod.yml logs -f",
    "stack:start": "powershell -ExecutionPolicy Bypass -File scripts/start-dev-stack.ps1 -Full",
    "stack:core": "powershell -ExecutionPolicy Bypass -File scripts/start-dev-stack.ps1 -Core",
    "stack:monitor": "powershell -ExecutionPolicy Bypass -File scripts/start-dev-stack.ps1 -Monitor",
    "stack:logs": "powershell -ExecutionPolicy Bypass -File scripts/start-dev-stack.ps1 -Logs",
    "stack:stop": "powershell -ExecutionPolicy Bypass -File scripts/start-dev-stack.ps1 -Stop",
    "stack:status": "powershell -ExecutionPolicy Bypass -File scripts/start-dev-stack.ps1 -Status",
    "stack:health": "powershell -ExecutionPolicy Bypass -File scripts/start-dev-stack.ps1 -Health",
    "redis:start": "redis-server redis/redis.conf",
    "redis:monitor": "redis-cli monitor",
    "redis:info": "redis-cli info",
    "redis:flush": "redis-cli flushall",
    "redis:optimize": "powershell -ExecutionPolicy Bypass -File scripts/redis/optimize-redis.ps1",
    "security:scan": "powershell -ExecutionPolicy Bypass -File scripts/security/security-update.ps1",
    "security:secrets": "powershell -ExecutionPolicy Bypass -File scripts/setup/setup-github-secrets.ps1",
    "deploy:dev": "powershell -ExecutionPolicy Bypass -File scripts/deploy/deploy.ps1 -Environment dev",
    "deploy:prod": "powershell -ExecutionPolicy Bypass -File scripts/deploy/deploy.ps1 -Environment prod",
    "setup:env": "powershell -ExecutionPolicy Bypass -File scripts/setup/setup-env.ps1",
    "setup:network": "powershell -ExecutionPolicy Bypass -File configure-network.ps1",
    "setup:full": "npm run setup:env && npm run setup:network && npm run db:generate",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "type-check": "nuxt typecheck",
    "analyze": "ANALYZE=true npm run build",
    "clean": "rimraf .nuxt dist .output",
    "clean:all": "npm run clean && rimraf node_modules && npm install",
    "update:deps": "npm update && npm audit fix",
    "update:deps:major": "npx npm-check-updates -u && npm install",
    "docs:generate": "powershell -ExecutionPolicy Bypass -File scripts/generate-docs.ps1",
    "docs:serve": "powershell -ExecutionPolicy Bypass -File scripts/serve-docs.ps1",
    "backup:full": "powershell -ExecutionPolicy Bypass -File scripts/utils/backup.sh",
    "restore:full": "powershell -ExecutionPolicy Bypass -File scripts/utils/restore.sh",
    "monitor:start": "powershell -ExecutionPolicy Bypass -File scripts/monitor/start-monitoring.ps1",
    "monitor:stop": "powershell -ExecutionPolicy Bypass -File scripts/monitor/stop-monitoring.ps1",
    "monitor:status": "powershell -ExecutionPolicy Bypass -File scripts/monitor/status.ps1",
    "ci:test": "npm run test && npm run type-check && npm run lint",
    "ci:build": "npm run build && npm run generate",
    "ci:deploy": "npm run ci:test && npm run ci:build && npm run deploy:prod",
    "dev:fast": "NODE_OPTIONS='--max-old-space-size=4096' nuxt dev",
    "dev:debug": "NODE_OPTIONS='--inspect' nuxt dev",
    "dev:profile": "NODE_OPTIONS='--prof' nuxt dev",
    "build:analyze": "ANALYZE=true npm run build",
    "build:prod": "NODE_ENV=production npm run build",
    "preview:prod": "npm run build:prod && npm run preview",
    "health:check": "curl -f http://localhost:3000/api/health || exit 1",
    "health:monitor": "watch -n 5 'curl -s http://localhost:3000/api/health | jq .'",
    "logs:tail": "tail -f logs/app.log",
    "logs:clear": "echo '' > logs/app.log",
    "cache:clear": "npm run perf:cleanup",
    "cache:warm": "npm run build && npm run db:generate",
    "maintenance:on": "echo 'maintenance' > .maintenance",
    "maintenance:off": "rm -f .maintenance",
    "backup:db": "npm run db:backup",
    "restore:db": "powershell -ExecutionPolicy Bypass -File scripts/utils/restore-database.ps1",
    "migrate:run": "npm run db:migrate",
    "migrate:reset": "npm run db:reset",
    "seed:run": "npm run db:seed",
    "studio:open": "npm run db:studio",
    "test:api": "newman run tests/api-collection.json",
    "test:e2e": "npm run test",
    "test:unit": "vitest",
    "test:coverage": "vitest --coverage",
    "test:watch": "vitest --watch",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "commit": "git-cz",
    "release": "standard-version",
    "release:patch": "npm run release -- --release-as patch",
    "release:minor": "npm run release -- --release-as minor",
    "release:major": "npm run release -- --release-as major"
  },
  "dependencies": {
    "@nuxt/content": "^3.6.3",
    "@nuxt/fonts": "^0.11.3",
    "@nuxt/icon": "^1.12.0",
    "@nuxt/image": "^1.10.0",
    "@nuxt/image-edge": "^1.3.0-28493895.369b747",
    "@nuxt/scripts": "^0.11.6",
    "@nuxt/test-utils": "^3.18.0",
    "@nuxtjs/color-mode": "^3.5.2",
    "@nuxtjs/i18n": "^10.0.2",
    "@nuxtjs/pwa": "^3.3.5",
    "@nuxtjs/seo": "^3.0.3",
    "@pinia/nuxt": "^0.5.1",
    "@prisma/client": "^6.12.0",
    "@supabase/supabase-js": "^2.52.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/ioredis": "^4.28.10",
    "@types/jsonwebtoken": "^9.0.10",
    "@unhead/vue": "^2.0.8",
    "@vite-pwa/nuxt": "^1.0.4",
    "@vueuse/core": "^13.2.0",
    "@vueuse/nuxt": "^13.1.0",
    "bcryptjs": "^2.4.3",
    "chart.js": "^4.4.2",
    "crypto": "^1.0.1",
    "echarts": "^5.5.0",
    "h3": "^1.15.3",
    "ioredis": "^5.3.2",
    "jsonwebtoken": "^9.0.2",
    "node-fetch": "^3.3.2",
    "nuxt-llms": "^0.1.2",
    "pinia": "^3.0.2",
    "redis": "^5.6.1",
    "three": "^0.176.0",
    "vanta": "^0.5.24",
    "vue": "^3.5.17",
    "vue-echarts": "^7.0.3",
    "vuedraggable": "^4.1.0",
    "vuetify": "^3.9.2"
  },
  "devDependencies": {
    "@nuxt/eslint-config": "^1.7.1",
    "@nuxt/image": "^1.10.0",
    "@nuxt/kit": "^4.0.1",
    "@nuxt/schema": "^4.0.1",
    "@playwright/test": "^1.54.1",
    "@types/echarts": "^4.9.22",
    "@types/node": "^24.1.0",
    "@typescript-eslint/eslint-plugin": "^8.38.0",
    "@vscode/test-electron": "^2.5.2",
    "@vue/eslint-config-prettier": "^10.2.0",
    "@vue/eslint-config-typescript": "^14.6.0",
    "@vue/test-utils": "^2.4.6",
    "audit-ci": "^7.0.0",
    "cross-env": "^7.0.3",
    "eslint": "^9.32.0",
    "eslint-config-prettier": "^10.1.5",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-nuxt": "^4.0.0",
    "eslint-plugin-vue": "^10.3.0",
    "globals": "^16.1.0",
    "happy-dom": "^17.4.7",
    "husky": "^8.0.0",
    "jsdom": "^26.1.0",
    "lighthouse": "^12.6.0",
    "lint-staged": "^15.2.2",
    "nuxt": "^3.17.3",
    "postcss": "^8.4.35",
    "postcss-custom-properties": "^14.0.6",
    "postcss-import": "^16.1.1",
    "postcss-preset-env": "^10.2.4",
    "prettier": "^3.5.3",
    "prisma": "^6.12.0",
    "stylelint": "^16.19.1",
    "stylelint-config-recommended": "^16.0.0",
    "stylelint-config-standard": "^38.0.0",
    "stylelint-config-standard-vue": "^1.0.0",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.32.1",
    "vitest": "^3.1.4",
    "vue-tsc": "^3.0.4"
  },
  "lint-staged": {
    "*.{js,ts,vue}": ["eslint --fix", "prettier --write"],
    "*.{css,scss,html}": ["prettier --write"]
  }
}
