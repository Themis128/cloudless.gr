{
  "name": "cloudless-app",
  "version": "0.1.0",
  "packageManager": "pnpm@10.33.2+sha512.a90faf6feeab71ad6c6e57f94e0fe1a12f5dcc22cd754db40ae9593eb6a3e0b6b12e3540218bb37ae083404b1f2ce6db2a4121e979829b4aff94b99f49da1cf8",
  "private": true,
  "engines": {
    "node": ">=20",
    "pnpm": ">=10"
  },
  "scripts": {
    "dev": "next dev -p 4000",
    "build": "next build",
    "start": "next start -p 4000",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix",
    "format": "prettier --write \"src/**/*.{ts,tsx,css,json}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,css,json}\"",
    "typecheck": "tsc --noEmit",
    "test": "vitest",
    "test:ci": "vitest run",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "playwright test --headed",
    "deploy": "sst deploy --stage production",
    "deploy:staging": "sst deploy --stage staging",
    "sst:dev": "sst dev",
    "devcontainer:preflight": "bash -lc 'if ! command -v docker >/dev/null 2>&1; then echo \"Docker CLI not found in this WSL distro. Enable Docker Desktop WSL integration for this distro.\"; exit 1; fi; if ! docker version >/dev/null 2>&1; then echo \"Docker daemon not reachable from WSL. Start Docker Desktop and wait for Engine running.\"; exit 1; fi; if command -v wsl.exe >/dev/null 2>&1; then wsl.exe -l -v; fi; echo \"Docker is ready for Dev Containers.\"'",
    "devcontainer:doctor": "bash scripts/devcontainer-doctor.sh",
    "devcontainer:stop": "bash scripts/devcontainer-stop.sh",
    "notion:test": "tsx --tsconfig scripts/tsconfig.json scripts/notion-test.ts",
    "gsc:sync": "tsx --tsconfig scripts/tsconfig.json scripts/weekly-gsc-sync.ts",
    "mcp-security-scan": "cd tools/mcp-security-scanner && npm install && npm run scan -- --path \"../../src/**/*.{ts,tsx,js,jsx,py,md}\"",
    "mcp-security-scan:server": "cd tools/mcp-security-scanner && npm install && npm run scan -- --path \"../../src/{app/api,lib}/**/*.{ts,tsx,js,jsx,py,md}\"",
    "test:e2e:fullstack": "playwright test e2e/fullstack-frontend-backend.spec.ts",
    "test:e2e:integrations": "playwright test e2e/integrations-contracts.spec.ts",
    "test:k3s": "playwright test --config=playwright.k3s.config.mts",
    "test:k3s:smoke": "playwright test --config=playwright.k3s.config.mts e2e/k3s/smoke.spec.ts"
  },
  "dependencies": {
    "@aws-sdk/client-cognito-identity-provider": "^3.1028.0",
    "@aws-sdk/client-dynamodb": "^3.1041.0",
    "@aws-sdk/client-ses": "^3.1028.0",
    "@aws-sdk/client-sesv2": "^3.1028.0",
    "@aws-sdk/client-ssm": "^3.1028.0",
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.5.0",
    "@sentry/nextjs": "^10.48.0",
    "aws-amplify": "^6.16.3",
    "cmdk": "^1.1.1",
    "countup.js": "^2.10.0",
    "es-abstract": "^1.24.2",
    "gsap": "^3.14.2",
    "jose": "^6.2.2",
    "lenis": "^1.3.21",
    "lucide-react": "^1.11.0",
    "next": "16.2.4",
    "next-intl": "^4.9.1",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "stripe": "^21.0.1",
    "three": "^0.183.2"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.10.1",
    "@parcel/watcher": "^2.5.6",
    "@playwright/test": "^1.59.1",
    "@tailwindcss/postcss": "^4.2.2",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^20.19.39",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/three": "^0.183.1",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^9.39.4",
    "eslint-config-next": "16.2.3",
    "jsdom": "^29.0.2",
    "prettier": "^3.8.1",
    "prettier-plugin-tailwindcss": "^0.6.14",
    "sst": "^4.7.0",
    "tailwindcss": "^4.2.2",
    "tsx": "^4.19.3",
    "typescript": "^5.9.3",
    "vite": "^8.0.8",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^4.1.4"
  },
  "pnpm": {
    "overrides": {
      "fast-xml-parser@<5.7.0": ">=5.7.0",
      "postcss@<8.5.10": ">=8.5.10",
      "uuid@<14.0.0": ">=14.0.0"
    },
    "onlyBuiltDependencies": [
      "@parcel/watcher",
      "@sentry/cli",
      "@swc/core",
      "esbuild"
    ]
  }
}
