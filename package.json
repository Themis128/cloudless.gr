{
  "name": "nuxt-app",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "nuxt build",
    "dev": "nuxt dev",
    "generate": "nuxt generate",
    "preview": "nuxt preview",
    "postinstall": "nuxt prepare",
    "prepare": "husky install",
    "stylelint": "stylelint '**/*.{css,vue}'",
    "type-check": "tsc --noEmit",
    "lint": "eslint . --fix",
    "format": "prettier --write .",
    "supabase:start": "docker-compose -f docker-compose.supabase.yml up -d",
    "supabase:stop": "docker-compose -f docker-compose.supabase.yml down",
    "supabase:reset": "docker-compose -f docker-compose.supabase.yml down -v && docker-compose -f docker-compose.supabase.yml up -d"
  },
  "dependencies": {
    "@auth0/auth0-vue": "^2.4.0",
    "@mdi/font": "^7.4.47",
    "@nuxt/content": "^3.5.1",
    "@nuxt/fonts": "^0.11.3",
    "@nuxt/icon": "^1.12.0",
    "@nuxt/image": "^1.10.0",
    "@nuxt/image-edge": "^1.3.0-28493895.369b747",
    "@nuxt/scripts": "^0.11.6",
    "@nuxt/test-utils": "^3.18.0",
    "@nuxt/ui": "^2.22.0",
    "@nuxtjs/color-mode": "^3.5.1",
    "@nuxtjs/seo": "^3.0.3",
    "@nuxtjs/supabase": "^1.5.1",
    "@prisma/client": "^5.22.0",
    "@stripe/stripe-js": "^7.3.1",
    "@supabase/supabase-js": "^2.50.0",
    "@unhead/vue": "^2.0.8",
    "@vueuse/core": "^13.2.0",
    "@vueuse/nuxt": "^13.1.0",
    "h3": "^1.13.0",
    "jsonwebtoken": "^9.0.2",
    "node-fetch": "^3.3.2",
    "nuxt": "^3.17.3",
    "nuxt-llms": "^0.1.2",
    "pinia": "^3.0.2",
    "prisma": "^5.22.0",
    "stripe": "^18.2.1",
    "three": "^0.176.0",
    "vanta": "^0.5.24",
    "vue": "^3.5.13",
    "vue-router": "^4.5.1",
    "vuetify": "^3.7.5"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.1",
    "@eslint/js": "^9.26.0",
    "@pinia/nuxt": "^0.11.0",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/node": "^22.15.30",
    "@types/three": "^0.176.0",
    "@typescript-eslint/eslint-plugin": "^8.32.1",
    "@typescript-eslint/parser": "^8.32.1",
    "@vitejs/plugin-vue": "^5.0.0",
    "cypress": "^13.16.0",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^10.1.5",
    "eslint-plugin-vue": "^10.1.0",
    "globals": "^16.1.0",
    "happy-dom": "^15.11.6",
    "husky": "^8.0.0",
    "lint-staged": "^15.2.2",
    "postcss": "^8.4.35",
    "prettier": "^3.5.3",
    "sass": "^1.81.0",
    "stylelint": "^16.19.1",
    "stylelint-config-recommended": "^16.0.0",
    "stylelint-config-standard": "^38.0.0",
    "stylelint-config-standard-vue": "^1.0.0",
    "supabase": "^2.24.3",
    "ts-node": "^10.9.2",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.32.1",
    "vitest": "^3.1.4"
  },
  "lint-staged": {
    "*.{js,ts,vue}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{css,scss,html}": [
      "prettier --write"
    ]
  }
}
