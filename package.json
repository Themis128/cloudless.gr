{
  "name": "nuxt-app",
  "private": true,
  "type": "module",
  "imports": {
    "#internal/nuxt/paths": "./node_modules/nuxt/dist/core/runtime/nitro/paths.mjs"
  },
  "scripts": {
    "build": "nuxt build",
    "build:analyze": "ANALYZE=true nuxt build",
    "dev": "nuxt dev",
    "dev:fix": "node scripts/dev-manager.mjs fix",
    "generate": "nuxt generate",
    "preview": "nuxt preview",
    "postinstall": "nuxt prepare",
    "prepare": "husky install",
    "stylelint": "stylelint '**/*.{css,vue}'",
    "type-check": "vue-tsc --noEmit",
    "type-check:watch": "vue-tsc --noEmit --watch",
    "type-check:big": "node --max-old-space-size=8192 ./node_modules/.bin/vue-tsc --noEmit",
    "type-fix": "npm run type-check && npm run lint",
    "type-fix:all": "npm run type-check && npm run lint && npm run format",
    "lint": "eslint . --fix",
    "lint:big": "node --max-old-space-size=8192 ./node_modules/.bin/eslint .",
    "format": "prettier --write .",
    "analyze": "nuxi analyze",
    "auto-fix": "node scripts/auto-fix-errors.mjs all",
    "auto-fix:scan": "node scripts/auto-fix-errors.mjs scan",
    "auto-fix:fix": "node scripts/auto-fix-errors.mjs fix",
    "auto-fix:verbose": "node scripts/auto-fix-errors.mjs all --verbose",
    "clean": "node scripts/clean.mjs",
    "check:supabase": "tsx scripts/check-supabase.ts",
    "clean:full": "node scripts/clean.mjs && rm -rf node_modules package-lock.json",
    "reinstall": "npm run clean:full && npm install",
    "fix-all": "npm run auto-fix && npm run type-check && npm run format",
    "health": "node scripts/health-check.mjs",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:ui": "vitest --ui",
    "test:python": "python -m pytest jenkins/python/ -v --junitxml=test-results/python-results.xml",
    "test:platform": "python tests/test_platform.py",
    "docker:dev": "docker-compose -f docker-compose.dev.yml up --build",
    "docker:dev:detached": "docker-compose -f docker-compose.dev.yml up --build -d",
    "docker:prod": "docker-compose -f docker-compose.prod.yml up --build",
    "docker:prod:detached": "docker-compose -f docker-compose.prod.yml up --build -d",
    "docker:stop": "docker-compose -f docker-compose.dev.yml down && docker-compose -f docker-compose.prod.yml down",
    "docker:clean": "docker-compose -f docker-compose.dev.yml down -v && docker-compose -f docker-compose.prod.yml down -v",
    "docker:logs": "docker-compose -f docker-compose.dev.yml logs -f nuxt-app",
    "docker:shell": "docker-compose -f docker-compose.dev.yml exec nuxt-app sh",
    "docker:build": "docker build -t cloudless-nuxt .",
    "docker:build:prod": "docker build --target production -t cloudless-nuxt:prod .",
    "docker:init": "node scripts/docker-setup.mjs init",
    "docker:setup": "node scripts/docker-setup.mjs",
    "docker:status": "node scripts/docker-setup.mjs status",
    "git:check": "node scripts/git-workflow.mjs check",
    "git:commit": "node scripts/git-workflow.mjs commit",
    "git:sync": "node scripts/git-workflow.mjs sync",
    "git:push": "node scripts/git-workflow.mjs push",
    "git:all": "node scripts/git-workflow.mjs all",
    "release": "standard-version",
    "release:minor": "standard-version --release-as minor",
    "release:major": "standard-version --release-as major",
    "release:patch": "standard-version --release-as patch",
    "release:dry-run": "standard-version --dry-run",
    "release:first": "standard-version --first-release",
    "release:prerelease": "standard-version --prerelease",
    "release:alpha": "standard-version --prerelease alpha",
    "release:beta": "standard-version --prerelease beta",
    "test:suite": "node scripts/test-suite.mjs all",
    "test:unit": "node scripts/test-suite.mjs unit",
    "test:e2e": "node scripts/test-suite.mjs e2e",
    "test:quality": "node scripts/test-suite.mjs quality",
    "test:build": "node scripts/test-suite.mjs build",
    "dev:env": "node scripts/dev-manager.mjs",
    "dev:setup": "node scripts/dev-manager.mjs setup",
    "dev:check": "node scripts/dev-manager.mjs check",
    "dev:status": "node scripts/dev-manager.mjs status",
    "dev:python": "node scripts/dev-manager.mjs python",
    "dev:docker": "node scripts/dev-manager.mjs docker",
    "dev:all": "node scripts/dev-manager.mjs all",
    "lint:python": "powershell -Command \"if (Test-Path .\\shared_venv\\Scripts\\flake8.exe) { .\\shared_venv\\Scripts\\flake8.exe backend agents server --count --show-source --statistics } else { Write-Host 'flake8 not found. Please install the Python dev environment and requirements.' -ForegroundColor Red }\"",
    "supabase:setup": "node scripts/setup-supabase.mjs",
    "docker:deploy:dev": "powershell -ExecutionPolicy Bypass -File deploy-docker.ps1 -Action dev",
    "docker:deploy:prod": "powershell -ExecutionPolicy Bypass -File deploy-docker.ps1 -Action prod",
    "docker:deploy:status": "powershell -ExecutionPolicy Bypass -File deploy-docker.ps1 -Action status",
    "docker:deploy:logs": "powershell -ExecutionPolicy Bypass -File deploy-docker.ps1 -Action logs",
    "docker:validate-env": "powershell -ExecutionPolicy Bypass -File deploy-docker.ps1 -Action dev -ValidateEnv",
    "docker:health": "node scripts/docker-health-check.mjs"
  },
  "dependencies": {
    "@auth/core": "^0.39.1",
    "@auth0/auth0-spa-js": "^2.2.0",
    "@auth0/auth0-vue": "^2.4.0",
    "@mdi/font": "^7.4.47",
    "@nuxt/content": "^3.5.1",
    "@nuxt/fonts": "^0.11.4",
    "@nuxt/icon": "^1.13.0",
    "@nuxt/image": "^1.10.0",
    "@nuxt/image-edge": "^1.3.0-28493895.369b747",
    "@nuxt/scripts": "^0.11.7",
    "@nuxt/test-utils": "^3.19.1",
    "@nuxtjs/color-mode": "^3.5.2",
    "@nuxtjs/seo": "^3.0.3",
    "@nuxtjs/supabase": "^1.5.1",
    "@supabase/supabase-js": "^2.49.10",
    "@types/bcryptjs": "^2.4.6",
    "@unhead/vue": "^2.0.10",
    "@vue-flow/core": "^1.44.0",
    "@vue/runtime-dom": "^3.5.16",
    "@vueuse/core": "^13.3.0",
    "@vueuse/nuxt": "^13.3.0",
    "bcryptjs": "^3.0.2",
    "h3": "^1.15.3",
    "jsonwebtoken": "^9.0.2",
    "minio": "^8.0.5",
    "node-fetch": "^3.3.2",
    "nuxt": "^3.17.4",
    "nuxt-llms": "^0.1.2",
    "pinia": "^3.0.2",
    "three": "^0.177.0",
    "vanta": "^0.5.24",
    "vue": "^3.5.16",
    "vue-router": "^4.5.1",
    "vuetify": "^3.8.7"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.1",
    "@eslint/js": "^9.28.0",
    "@nuxt/eslint-config": "^1.4.1",
    "@nuxt/types": "^2.18.1",
    "@pinia/nuxt": "^0.11.0",
    "@types/dockerode": "^3.3.39",
    "@types/jsonwebtoken": "^9.0.9",
    "@types/lodash": "^4.17.17",
    "@types/node": "^22.15.29",
    "@types/three": "^0.176.0",
    "@types/vue": "^2.0.0",
    "@typescript-eslint/eslint-plugin": "^8.33.0",
    "@typescript-eslint/parser": "^8.33.0",
    "@vitejs/plugin-vue": "^5.2.4",
    "@vitest/coverage-v8": "^3.1.4",
    "@vitest/ui": "^3.1.4",
    "@vue/compiler-sfc": "^3.5.16",
    "@vue/tsconfig": "^0.7.0",
    "autoprefixer": "^10.4.21",
    "chokidar": "^4.0.3",
    "concurrently": "^9.1.2",
    "cross-env": "^7.0.3",
    "cspell": "^9.0.2",
    "cypress": "^14.4.0",
    "docker-compose": "^1.2.0",
    "dockerode": "^4.0.6",
    "dotenv": "^16.5.0",
    "eslint": "^9.28.0",
    "eslint-config-prettier": "^10.1.5",
    "eslint-plugin-vue": "^10.1.0",
    "fs-extra": "^11.3.0",
    "glob": "^11.0.2",
    "globals": "^16.2.0",
    "happy-dom": "^17.5.6",
    "husky": "^9.1.7",
    "js-yaml": "^4.1.0",
    "jsdom": "^26.1.0",
    "lint-staged": "^16.1.0",
    "nodemon": "^3.1.10",
    "postcss": "^8.5.4",
    "postcss-import": "^16.1.0",
    "postcss-nesting": "^13.0.1",
    "prettier": "^3.5.3",
    "rimraf": "^6.0.1",
    "sass": "^1.89.1",
    "standard-version": "^9.5.0",
    "stylelint": "^16.20.0",
    "stylelint-config-recommended": "^16.0.0",
    "stylelint-config-standard": "^38.0.0",
    "stylelint-config-standard-vue": "^1.0.0",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.33.0",
    "vite-tsconfig-paths": "^5.1.4",
    "vitest": "^3.1.4",
    "vue-eslint-parser": "^10.1.3",
    "vue-tsc": "^2.2.10",
    "wait-on": "^8.0.3",
    "webpack-bundle-analyzer": "^4.10.2"
  },
  "lint-staged": {
    "*.{js,ts,vue}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{css,scss,html}": [
      "prettier --write"
    ],
    "*.{json,md,yml,yaml}": [
      "prettier --write"
    ]
  }
}
