[
  {
    "key": "ctrl+shift+f12",
    "command": "workbench.action.tasks.runTask",
    "args": "🤖 Run Auto-Fix Script",
    "when": "editorTextFocus"
  },
  {
    "key": "ctrl+shift+f11",
    "command": "workbench.action.tasks.runTask",
    "args": "🔧 Auto Fix ESLint Errors",
    "when": "editorTextFocus"
  },
  {
    "key": "ctrl+shift+f10",
    "command": "workbench.action.tasks.runTask",
    "args": "🎨 Auto Format All Files",
    "when": "editorTextFocus"
  },
  {
    "key": "ctrl+shift+t",
    "command": "workbench.action.tasks.runTask",
    "args": "🔍 Type Check",
    "when": "editorTextFocus"
  },
  {
    "key": "ctrl+shift+b",
    "command": "workbench.action.tasks.runTask",
    "args": "Build",
    "when": "editorTextFocus"
  },
  {
    "key": "ctrl+shift+d",
    "command": "workbench.action.tasks.runTask",
    "args": "Dev Server",
    "when": "editorTextFocus"
  },
  {
    "key": "ctrl+shift+c",
    "command": "workbench.action.tasks.runTask",
    "args": "🧹 Clean All Caches",
    "when": "editorTextFocus"
  },
  {
    "key": "f5",
    "command": "workbench.action.debug.start",
    "when": "!inDebugMode"
  },
  {
    "key": "shift+f5",
    "command": "workbench.action.debug.stop",
    "when": "inDebugMode"
  },
  {
    "key": "ctrl+shift+f5",
    "command": "workbench.action.debug.restart",
    "when": "inDebugMode"
  },
  {
    "key": "ctrl+shift+e",
    "command": "eslint.executeAutofix",
    "when": "editorTextFocus && editorLangId =~ /vue|typescript|javascript/"
  },
  {
    "key": "ctrl+shift+p",
    "command": "editor.action.formatDocument",
    "when": "editorTextFocus"
  },
  {
    "key": "ctrl+shift+i",
    "command": "editor.action.organizeImports",
    "when": "editorTextFocus && editorLangId =~ /vue|typescript|javascript/"
  },
  {
    "key": "ctrl+shift+r",
    "command": "typescript.restartTsServer",
    "when": "editorTextFocus && editorLangId =~ /vue|typescript|javascript/"
  },
  {
    "key": "ctrl+shift+m",
    "command": "workbench.panel.markers.view.focus"
  },
  {
    "key": "ctrl+shift+q",
    "command": "workbench.action.showErrorsWarnings"
  },
  {
    "key": "alt+shift+f",
    "command": "editor.action.quickFix",
    "when": "editorTextFocus"
  },
  {
    "key": "ctrl+k ctrl+f",
    "command": "editor.action.formatSelection",
    "when": "editorHasSelection && editorTextFocus"
  },
  {
    "key": "ctrl+shift+h",
    "command": "workbench.action.tasks.runTask",
    "args": "🏥 Health Check",
    "when": "editorTextFocus"
  },
  {
    "key": "ctrl+shift+g",
    "command": "workbench.action.tasks.runTask",
    "args": "🌟 Git Smart Commit",
    "when": "editorTextFocus"
  },
  {
    "key": "ctrl+alt+g",
    "command": "workbench.action.tasks.runTask",
    "args": "🔄 Git Sync & Push",
    "when": "editorTextFocus"
  },
  {
    "key": "ctrl+shift+alt+d",
    "command": "workbench.action.tasks.runTask",
    "args": "🚀 Dev Server with Auto-Fix",
    "when": "editorTextFocus"
  }
]
