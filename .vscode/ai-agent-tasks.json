{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "AI Agent: Start Dev Server",
      "type": "shell",
      "command": "npx nuxt dev",
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": false,
        "panel": "shared",
        "showReuseMessage": true,
        "clear": false
      },
      "problemMatcher": ["$tsc"],
      "runOptions": {
        "runOn": "folderOpen"
      }
    },
    {
      "label": "AI Agent: Build Production",
      "type": "shell",
      "command": "npx nuxt build",
      "group": "build",
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": true,
        "panel": "shared"
      },
      "problemMatcher": ["$tsc"]
    },
    {
      "label": "AI Agent: Generate Static Site",
      "type": "shell",
      "command": "npx nuxt generate",
      "group": "build",
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": true,
        "panel": "shared"
      }
    },
    {
      "label": "AI Agent: Prisma Studio",
      "type": "shell",
      "command": "npx prisma studio",
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": false,
        "panel": "new"
      },
      "isBackground": true
    },
    {
      "label": "AI Agent: Run Tests",
      "type": "shell",
      "command": "npm run test",
      "group": "test",
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": true,
        "panel": "shared"
      },
      "problemMatcher": ["$tsc"]
    },
    {
      "label": "AI Agent: Lint & Fix",
      "type": "shell",
      "command": "npm run lint -- --fix",
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": true,
        "panel": "shared"
      },
      "problemMatcher": ["$eslint-stylish"]
    },
    {
      "label": "AI Agent: Clean Cache",
      "type": "shell",
      "command": "npx nuxt cleanup && npm run build",
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": true,
        "panel": "shared"
      }
    },
    {
      "label": "AI Agent: Database Reset",
      "type": "shell",
      "command": "npx prisma migrate reset --force && npx prisma db push && npx prisma generate",
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": true,
        "panel": "shared"
      }
    },
    {
      "label": "AI Agent: Full Restart",
      "type": "shell",
      "command": "taskkill /f /im node.exe 2>nul & npx nuxt cleanup & npm install & npx nuxt dev",
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": true,
        "panel": "shared",
        "clear": true
      },
      "group": {
        "kind": "build",
        "isDefault": false
      }
    }
  ]
}
