    "description": "Vuetify 3 card with actions",
  },

  "Vuetify 3 Navigation Drawer": {
    "prefix": "v3-drawer",
    "body": [
      "<v-navigation-drawer",
      "  v-model=\"${1:drawer}\"",
      "  ${2:rail}",
      "  ${3:permanent}",
      ">",
      "  <v-list density=\"compact\" nav>",
      "    <v-list-item",
      "      v-for=\"item in ${4:navigationItems}\"",
      "      :key=\"item.title\"",
      "      :to=\"item.to\"",
      "      :prepend-icon=\"item.icon\"",
      "      :title=\"item.title\"",
      "    />",
      "  </v-list>",
      "</v-navigation-drawer>",
    ],
    "description": "Vuetify 3 navigation drawer",
  },

  "Vuetify 3 App Layout": {
    "prefix": "v3-layout",
    "body": [
      "<template>",
      "  <v-app>",
      "    <v-app-bar",
      "      :elevation=\"2\"",
      "      color=\"primary\"",
      "    >",
      "      <v-app-bar-nav-icon @click=\"drawer = !drawer\" />",
      "      <v-app-bar-title>${1:App Title}</v-app-bar-title>",
      "      <v-spacer />",
      "    </v-app-bar>",
      "    ",
      "    <v-navigation-drawer v-model=\"drawer\">",
      "      <!-- Navigation content -->",
      "    </v-navigation-drawer>",
      "    ",
      "    <v-main>",
      "      <v-container fluid>",
      "        ${2:<!-- Main content -->}",
      "        <slot />",
      "      </v-container>",
      "    </v-main>",
      "    ",
      "    <v-footer app>",
      "      ${3:<!-- Footer content -->}",
      "    </v-footer>",
      "  </v-app>",
      "</template>",
      "",
      "<script setup>",
      "const drawer = ref(${4:false})",
      "</script>",
    ],
    "description": "Complete Vuetify 3 app layout",
  },

  "Vue 3 Composable": {
    "prefix": "vue3-composable",
    "body": [
      "import { ref, computed, reactive } from 'vue'",
      "",
      "export function use${1:Name}() {",
      "  const ${2:state} = ref(${3:null})",
      "  const ${4:loading} = ref(false)",
      "  const ${5:error} = ref(null)",
      "  ",
      "  const ${6:computedValue} = computed(() => {",
      "    return ${7:// computed logic}",
      "  })",
      "  ",
      "  async function ${8:fetchData}() {",
      "    ${4:loading}.value = true",
      "    ${5:error}.value = null",
      "    ",
      "    try {",
      "      ${9:// async logic}",
      "    } catch (err) {",
      "      ${5:error}.value = err",
      "    } finally {",
      "      ${4:loading}.value = false",
      "    }",
      "  }",
      "  ",
      "  return {",
      "    ${2:state},",
      "    ${4:loading},",
      "    ${5:error},",
      "    ${6:computedValue},",
      "    ${8:fetchData}",
      "  }",
      "}",
    ],
    "description": "Vue 3 composable function template",
  },

