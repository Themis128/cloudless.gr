    "body": [
      "export default defineEventHandler(async (event) => {",
      "  const method = getMethod(event)",
      "  ",
      "  if (method === 'GET') {",
      "    ${1:// Handle GET request}",
      "    return {",
      "      success: true,",
      "      data: ${2:null}",
      "    }",
      "  }",
      "  ",
      "  if (method === 'POST') {",
      "    const body = await readBody(event)",
      "    ${3:// Handle POST request}",
      "    return {",
      "      success: true,",
      "      data: ${4:null}",
      "    }",
      "  }",
      "  ",
      "  throw createError({",
      "    statusCode: 405,",
      "    statusMessage: 'Method Not Allowed'",
      "  })",
      "})",
