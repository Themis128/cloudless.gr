# Optimized Development Dockerfile for Cloudless.gr
# Designed for hot-reload and fast development cycles
# Addresses Vuetify loading bottlenecks and Nitro build timeouts

# Use Node.js 20 Alpine for smaller image size
FROM node:20-alpine

# Install system dependencies for development
RUN apk add --no-cache \
  curl \
  git \
  python3 \
  make \
  g++ \
  bash \
  vim \
  htop \
  procps \
  dumb-init \
  && rm -rf /var/cache/apk/*

# Set working directory
WORKDIR /app

# Create non-root user for security
RUN addgroup -g 1001 -S nodejs && \
  adduser -S nuxtjs -u 1001 -G nodejs

# Install pnpm globally to avoid downloads during startup
RUN npm install -g pnpm@10.13.1

# Copy package files first for better caching
COPY package*.json pnpm-lock.yaml* ./
COPY nuxt.config.ts ./
COPY tsconfig.json ./

# Install dependencies as root (will be changed to nuxtjs later)
# Use parallel processing and caching for faster installation
RUN pnpm install --frozen-lockfile --prefer-offline --network-concurrency=8 --child-concurrency=8

# Copy Prisma schema and generate client with parallel processing
COPY prisma ./prisma/
RUN npx prisma generate --schema=./prisma/schema.prisma

# Create necessary directories for development first
RUN mkdir -p \
    /app/.nuxt \
    /app/.output \
    /app/dist \
    /app/coverage \
    /app/.vite \
    /app/playwright-report \
    /app/logs \
    /app/uploads \
    /app/tmp \
    /app/node_modules/.cache \
    /app/node_modules/.cache/vite \
    /app/node_modules/.cache/vite/client \
    /app/node_modules/.cache/vite/server

# Copy the rest of the application with proper ownership
COPY --chown=nuxtjs:nodejs . .

# Fix permissions for all directories and files
RUN chown -R nuxtjs:nodejs /app && \
    chmod -R 755 /app && \
    chmod -R 777 /app/node_modules/.cache && \
    chmod -R 777 /app/.vite && \
    chmod -R 777 /app/.nuxt && \
    chmod -R 777 /app/.output

# Pre-build Vuetify components to avoid runtime loading delays
RUN pnpm exec nuxt build --dry-run || echo "Dry run completed"

# Pre-warm Vuetify cache to avoid slow transforms
RUN mkdir -p /app/.vite && \
    echo "Pre-warming Vuetify cache..." && \
    pnpm exec nuxt prepare || echo "Prepare completed"

# Switch to non-root user
USER nuxtjs

# Expose ports for development
EXPOSE 3000 24678 9229 9323

# Set development environment variables
ENV NODE_ENV=development
ENV NITRO_HOST=0.0.0.0
ENV NITRO_PORT=3000
ENV NUXT_HOST=0.0.0.0
ENV NUXT_PORT=3000
ENV HOST=0.0.0.0

# Ultra-fast file watching optimizations
ENV CHOKIDAR_USEPOLLING=true
ENV CHOKIDAR_INTERVAL=50
ENV CHOKIDAR_IGNORED="**/node_modules/**,**/.git/**,**/.nuxt/**,**/.output/**,**/dist/**,**/coverage/**,**/tmp/**,**/logs/**,**/*.log,**/.vite/**,**/playwright-report/**"
ENV WATCHPACK_POLLING=true
ENV WATCHPACK_AGGREGATE_TIMEOUT=50
ENV WATCHPACK_POLL=500

# Vite optimizations for instant hot reload
ENV VITE_HMR_PORT=24678
ENV VITE_HMR_HOST=0.0.0.0
ENV VITE_HMR_OVERLAY=false
ENV VITE_OPTIMIZE_DEPS_INCLUDE="vuetify,echarts,vue-echarts,@mdi/font"
ENV VITE_OPTIMIZE_DEPS_EXCLUDE="vue-demi"
ENV VITE_DEV_SERVER_WATCH_OPTIONS="usePolling:true,interval:50"

# Node.js optimizations for development with parallelization
ENV NODE_OPTIONS="--max-old-space-size=4096 --enable-source-maps --max-semi-space-size=512"

# Hot reload with enhanced debugging
ENV NUXT_DEV_SERVER_WATCH_OPTIONS="usePolling:true,interval:50,followSymlinks:false,ignored:[\"**/node_modules/**\",\"**/.git/**\",\"**/.nuxt/**\",\"**/.output/**\",\"**/playwright-report/**\"]"
ENV NUXT_DEV_SERVER_HMR_OPTIONS="port:24678,host:0.0.0.0,overlay:false,timeout:30000"

# Development debugging
ENV NITRO_DEBUG=1
ENV DEBUG="nuxt:*,nitro:*,vite:*"

# Timezone
ENV TZ=Europe/Athens

# Development features
ENV NUXT_TELEMETRY_DISABLED=1
ENV NITRO_PRESET=node
ENV NITRO_COMPRESSION=false
ENV NITRO_MINIFY=false

# Parallel processing optimizations
ENV UV_THREADPOOL_SIZE=8
ENV NITRO_MAX_PARALLEL=8
ENV NITRO_WORKERS=4
ENV NITRO_WORKER_CONCURRENCY=2

# Optimized health check with longer timeout and retries
HEALTHCHECK --interval=60s --timeout=30s --start-period=300s --retries=5 \
  CMD curl -f http://localhost:3000/api/health/simple || \
  curl -f http://localhost:3000/api/health || \
  curl -f http://localhost:3000/ || \
  exit 1

# Use dumb-init for proper signal handling
ENTRYPOINT ["dumb-init", "--"]

# Start development server with hot reload
CMD ["pnpm", "run", "dev"]
