# Development Dockerfile for Cloudless.gr
# Optimized for fast builds, hot reload, and development experience

FROM node:20-alpine

# Install system dependencies for development
RUN apk add --no-cache \
    curl \
    git \
    python3 \
    make \
    g++ \
    bash \
    vim \
    htop \
    procps \
    && rm -rf /var/cache/apk/*

# Set working directory
WORKDIR /app

# Create non-root user with proper permissions
RUN addgroup -g 1001 -S nodejs && \
    adduser -S nuxtjs -u 1001 -G nodejs

# Install global development tools
RUN npm install -g \
    nodemon \
    @nuxt/cli \
    typescript \
    ts-node \
    && npm cache clean --force

# Copy package files for better caching
COPY package*.json ./
COPY nuxt.config.ts ./
COPY tsconfig.json ./

# Install dependencies with development optimizations
RUN npm ci --include=dev && \
    npm cache clean --force

# Copy source code
COPY . .

# Create necessary directories and set permissions
RUN mkdir -p /app/.nuxt /app/.output /app/dist /app/coverage /app/.vite /app/playwright-report && \
    chown -R nuxtjs:nodejs /app

# Switch to non-root user
USER nuxtjs

# Expose ports for development
EXPOSE 3000 9229 24678

# Health check with better retry logic
HEALTHCHECK --interval=30s --timeout=10s --start-period=180s --retries=10 \
    CMD curl -f http://localhost:3000/api/health || exit 1

# Development command with enhanced debugging
CMD ["npm", "run", "dev:ultra"] 