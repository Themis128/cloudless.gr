# Development Dockerfile for Cloudless.gr
# Optimized for fast builds, hot reload, and development experience

FROM node:20-alpine

# Install system dependencies for development, Playwright, and Cypress
RUN apk add --no-cache \
    curl \
    git \
    python3 \
    make \
    g++ \
    bash \
    vim \
    htop \
    procps \
    powershell \
    udev \
    ttf-freefont \
    nss \
    chromium \
    xvfb \
    libnss3 \
    freetype \
    harfbuzz \
    ca-certificates \
    && rm -rf /var/cache/apk/*

# Set working directory
WORKDIR /app

# Create non-root user with proper permissions
RUN addgroup -g 1001 -S nodejs && \
    adduser -S nuxtjs -u 1001 -G nodejs

# Install pnpm and global development tools
RUN npm install -g pnpm prisma

# Copy package files for better caching
COPY package*.json ./
COPY pnpm-lock.yaml ./
COPY nuxt.config.ts ./
COPY tsconfig.json ./

# Install dependencies with pnpm
RUN pnpm install --frozen-lockfile

# Copy source code
COPY . .

# Create necessary directories and set permissions
RUN mkdir -p /app/.nuxt /app/.output /app/dist /app/coverage /app/.vite /app/playwright-report && \
    chown -R nuxtjs:nodejs /app

# Switch to non-root user
USER nuxtjs

# Expose ports for development
EXPOSE 3000 9229 24678

# Health check with better retry logic
HEALTHCHECK --interval=30s --timeout=10s --start-period=180s --retries=10 \
    CMD curl -f http://localhost:3000/api/health || exit 1

# Development command with enhanced debugging
CMD ["pnpm", "dev"] 