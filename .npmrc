# Fix pnpm hoisting issues with Next.js and AWS Amplify
public-hoist-pattern[]=*@aws-amplify/*
public-hoist-pattern[]=*@formatjs/*
public-hoist-pattern[]=*intl-messageformat*
public-hoist-pattern[]=*use-intl*
public-hoist-pattern[]=*next-intl*

# Ensure strict peer dependencies don't break builds
strict-peer-dependencies=false
auto-install-peers=true

# Next.js optimizations
node-linker=hoisted