# Environment variables for Cloudless.gr
# Copy this file to .env and fill in your actual values

# === SUPABASE CONFIGURATION ===
# Get these from your Supabase project settings
SUPABASE_URL=your_supabase_project_url
SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# === DATABASE CONFIGURATION ===
# For Supabase, this should match your Supabase database URL
DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT-REF].supabase.co:5432/postgres

# === LLM INTEGRATION ===
# Configuration for your local LLM server (Ollama)
LLM_API_URL=http://localhost:11434/api/generate
LLM_MODEL=phind-codellama:34b

# === ADMIN AUTHENTICATION ===
# For development only - use proper authentication in production
ADMIN_USERNAME=admin
ADMIN_PASSWORD=cloudless2025

# === JWT CONFIGURATION ===
# Generate a secure secret for JWT tokens
JWT_SECRET=your_very_secure_jwt_secret_here

# === EMAIL CONFIGURATION (Optional) ===
# For sending contact form notifications
SMTP_HOST=your_smtp_host
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_smtp_username
SMTP_PASS=your_smtp_password
EMAIL_FROM=noreply@cloudless.gr
EMAIL_TO=contact@cloudless.gr

# === MINIO/S3 CONFIGURATION (Optional) ===
# For file storage
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=cloudless-files

# === DEVELOPMENT SETTINGS ===
NODE_ENV=development
NUXT_PUBLIC_SITE_URL=http://localhost:3000

# === PRODUCTION SETTINGS (uncomment for production) ===
# NODE_ENV=production
# NUXT_PUBLIC_SITE_URL=https://cloudless.gr
