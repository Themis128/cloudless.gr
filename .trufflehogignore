# Vue, CSS and common keys
.*:key="[^"]*"
.*:key='[^']*'
.*v-bind:key="[^"]*"
.*v-bind:key='[^']*'
.*@keyframes.*
.*\.vue$
.*\.css$
.*\.scss$
.*\.less$
.*\.svg$
.*\.map$

# Common variable patterns
.*const\s+(password|token|key|secret)\s+=\s+['"].*['"]
.*let\s+(password|token|key|secret)\s+=\s+['"].*['"]
.*var\s+(password|token|key|secret)\s+=\s+['"].*['"]
.*const key = .*
.*let key = .*
.*var key = .*
.*const token = .*
.*let token = .*
.*var token = .*
.*const password = .*
.*let password = .*
.*var password = .*
.*const secret = .*
.*let secret = .*
.*var secret = .*

# Legit package names
.*path-key.*
.*ajv-keywords.*
.*key.*package.*
.*token.*package.*

# Placeholder tokens
.*//.*your_api_key_here.*
.*//.*your_secret_here.*
.*//.*your_password_here.*
.*//.*your_token_here.*
.*/\*.*your_api_key_here.*
.*/\*.*your_secret_here.*
.*/\*.*your_password_here.*
.*/\*.*your_token_here.*

# GitHub Actions secrets
.*\${{ secrets\..* }}
.*\${{ github\.secrets\..* }}

# Markdown reports
^SECRETS_SCAN_ANALYSIS\.md$
^GITHUB_SECRETS_SETUP\.md$

# Environment variables and configuration
.*process\.env\..*
.*NUXT_PUBLIC_.*
.*SUPABASE_.*
.*VITE_.*
.*NEXT_PUBLIC_.*

# Common false positive patterns
.*secret.*:.*
.*key.*:.*
.*token.*:.*
.*password.*:.*
.*api.*key.*
.*access.*key.*
.*private.*key.*
.*public.*key.*

# Database and foreign keys
.*foreignKeyName.*
.*_fkey.*
.*primaryKey.*
.*foreignKey.*

# JavaScript object notation
.*window\..*
.*document\..*
.*console\..*
.*VANTA\..*

# Version and metadata
.*Version:.*
.*version:.*
.*1\.0\.0.*
.*2\.0\.0.*
.*3\.0\.0.*

# SVG/XML attributes
.*xmlns.*
.*viewBox.*
.*width=.*
.*height=.*
.*fill=.*
.*stroke=.*

# File exclusions
^scripts/.*\.ps1$
^scripts/.*\.sh$
^Dockerfile$
^pages/.+\.vue$
^env\.example$
^\.env\.example$
^\.env\.local$
^\.env\.development$
^\.env\.production$

# Documentation and examples
^README\.md$
^docs/.*
^examples/.*
^templates/.*
^vanta-gallery/.*

# Additional specific exclusions
.*process\.env\.CI.*
.*process\.env\.NODE_ENV.*
.*process\.env\.NODE_VERSION.*
.*foreignKeyName.*
.*window\.VANTA\.CLOUDS2.*
.*Version:.*
.*xmlns=.*
.*viewBox=.* 