{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "Node",
    "strict": true,
    "jsx": "preserve",
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "baseUrl": ".",
    "paths": {
      "@/*": ["./*"],
      "~/*": ["./*"],
      "#/*": ["./*"],
      "~~/*": ["./*"],
      "@@/*": ["./*"],
      "assets/*": ["assets/*"],
      "public/*": ["public/*"]
    }
  },
  "types": [
    "@nuxt/kit",
    "@nuxt/schema",
    "@nuxt/types",
    "@nuxtjs/supabase",
    "@types/node"
  ],
  "exclude": [
    "node_modules",
    ".output",
    ".nuxt",
    "pages/debug/[type].vue/[id].vue",
    "components/bots/BotWizard.vue"
  ]
}
