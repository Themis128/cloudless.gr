{
  // https://nuxt.com/docs/guide/concepts/typescript
  "extends": "./.nuxt/tsconfig.json",
  "compilerOptions": {
    "module": "ESNext",
    "types": ["@playwright/test"]
  },
  "exclude": [
    "node_modules",
    ".output",
    ".nuxt",
    "dist",
    "build",
    "cypress",
    "playwright",
    "test-results",
    "db-backups",
    "jenkins-reports",
    "docker/**/*",
    "test-*.mjs",
    "test-*.js",
    "backup-*.ps1",
    "pages/projects/[id]/train-clean.vue"
  ]
}
