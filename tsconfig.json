{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "Node",
    "strict": true,
    "jsx": "preserve",
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "baseUrl": ".",
    "paths": {
      "@/*": ["./*"],
      "~/*": ["./*"],
      "#/*": ["./*"],
      "~~/*": ["./*"],
      "@@/*": ["./*"],
      "assets/*": ["assets/*"],
      "public/*": ["public/*"]
    }
  },
  "exclude": ["node_modules", ".output", ".nuxt"]
}
