{
  "name": "Text Classification Model",
  "description": "A model for classifying text into categories",
  "type": "classification",
  "framework": "transformers",
  "version": "1.0.0",
  "config": {
    "architecture": "bert-base-uncased",
    "parameters": {
      "epochs": 10,
      "batch_size": 32,
      "learning_rate": 0.001,
      "optimizer": "adam"
    },
    "data": {
      "train_split": 0.8,
      "validation_split": 0.1,
      "test_split": 0.1
    }
  },
  "category": "nlp",
  "tags": ["classification", "text", "nlp", "bert"]
}
