# Optimized .dockerignore for Development - Only exclude what's truly unnecessary

# Dependencies (installed in container)
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Build outputs (generated in container)
.nuxt/
.output/
dist/
.next/
out/
build/

# Environment files (mounted)
.env*
!.env.example
!.env.template

# IDE files
.vscode/
.idea/
*.swp
*.swo
*~

# OS files
.DS_Store
Thumbs.db
desktop.ini

# Git (large repository)
.git/
.gitignore
.gitattributes

# Docker files
Dockerfile*
docker-compose*.yml
.dockerignore*

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Runtime data
pids/
*.pid
*.seed
*.pid.lock

# Coverage
coverage/
*.lcov
.nyc_output/

# Cache directories
.npm/
.cache/
.parcel-cache/
.rpt2_cache/
.rts2_cache_cjs/
.rts2_cache_es/
.rts2_cache_umd/

# Temporary folders
tmp/
temp/
.tmp/

# Test files
tests/
test/
__tests__/
*.test.js
*.test.ts
*.spec.js
*.spec.ts

# Documentation (keep essential)
*.md
!README.md
docs/
documentation/

# Scripts (exclude most, keep essential)
scripts/
!scripts/server/

# Development tools
.eslintrc*
.prettierrc*
.prettierignore
.editorconfig
.babelrc*
jest.config.*

# CI/CD
.github/
.gitlab-ci.yml
.travis.yml
.circleci/
azure-pipelines.yml

# Large directories that slow builds (exclude completely)
vanta-master/
vanta-gallery/
playwright-report/
uploads/
runner-cache/
runner-data/
runner-logs/
github-runner/
github-runner-optimized/

# Development-specific exclusions
*.ps1
*.sh
!scripts/server/*.sh

# Cache and temporary files
.cursor/
*.tmp
*.temp

# Backup files
*.bak
*.backup
*.old

# Archive files
*.zip
*.tar.gz
*.rar

# Local development
.local/
local/

# Performance profiling
*.cpuprofile
*.heapsnapshot

# Security
.npmrc
.yarnrc

