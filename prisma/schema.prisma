generator client {
  provider = "prisma-client-js"
  output   = "../node_modules/.prisma/client"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id         Int         @id @default(autoincrement())
  email      String      @unique
  password   String
  name       String
  role       String      @default("user")
  isActive   Boolean     @default(true)
  isVerified Boolean     @default(false)
  lastLogin  DateTime?
  loginAttempts Int      @default(0)
  lockedUntil DateTime?
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt

  // Relations
  bots       Bot[]
  components Component[]
  models     Model[]
  pipelines  Pipeline[]
  projects   Project[]
  sessions   Session[]
  loginHistory LoginHistory[]
  passwordResetTokens PasswordResetToken[]
  emailVerificationTokens EmailVerificationToken[]
  userRoles  UserRole[]
  datasets   Dataset[]
}

// Session management for better security
model Session {
  id        String   @id @default(cuid())
  userId    Int
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  token     String   @unique
  expiresAt DateTime
  ipAddress String?
  userAgent String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Login history for security monitoring
model LoginHistory {
  id        Int      @id @default(autoincrement())
  userId    Int
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  ipAddress String?
  userAgent String?
  success   Boolean
  createdAt DateTime @default(now())
}

// Password reset tokens
model PasswordResetToken {
  id        String   @id @default(cuid())
  userId    Int
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  token     String   @unique
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())
}

// Email verification tokens
model EmailVerificationToken {
  id        String   @id @default(cuid())
  userId    Int
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  token     String   @unique
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())
}

// Rate limiting for security
model RateLimit {
  id        String   @id @default(cuid())
  key       String   @unique // IP address or user ID
  type      String   // "login", "api", "register"
  count     Int      @default(1)
  windowStart DateTime
  windowEnd   DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model Project {
  id             Int            @id @default(autoincrement())
  project_name   String
  slug           String         @unique
  overview       String
  description    String
  live_url       String?
  github_url     String?
  status         String         @default("draft")
  category       String?
  client         String?
  clientLogo     String?
  featured       Boolean        @default(false)
  isFavorite     Boolean        @default(false)
  completionDate String?
  duration       String?
  teamSize       Int?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  userId         Int
  user           User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Relations
  tags          ProjectTag[]
  images        ProjectImage[]
  testimonials  Testimonial[]
}

model ProjectTag {
  id          Int      @id @default(autoincrement())
  name        String
  color       String?
  primary     Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  projects    Project[]
}

model ProjectImage {
  id          Int      @id @default(autoincrement())
  img_name    String
  img_url     String
  is_thumbnail Boolean @default(false)
  alt         String?
  caption     String?
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  projectId   Int
  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

model Testimonial {
  id        Int      @id @default(autoincrement())
  quote     String
  author    String
  position  String?
  company   String?
  rating    Int      @default(5)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  projectId Int
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

model Bot {
  id          String   @id @default(cuid())
  name        String
  description String?
  type        String   @default("chatbot")
  status      String   @default("draft")
  config      String?  // JSON configuration
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  userId      Int
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Relations
  deployments BotDeployment[]
}

model BotDeployment {
  id        String   @id @default(cuid())
  botId     String
  bot       Bot      @relation(fields: [botId], references: [id], onDelete: Cascade)
  status    String   @default("pending")
  url       String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Model {
  id          String   @id @default(cuid())
  name        String
  description String?
  type        String   @default("llm")
  status      String   @default("draft")
  config      String?  // JSON configuration
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  userId      Int
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Relations
  trainings  ModelTraining[]
}

model ModelTraining {
  id        String   @id @default(cuid())
  modelId   String
  model     Model    @relation(fields: [modelId], references: [id], onDelete: Cascade)
  status    String   @default("pending")
  progress  Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Pipeline {
  id          String   @id @default(cuid())
  name        String
  description String?
  type        String   @default("data")
  status      String   @default("draft")
  config      String?  // JSON configuration
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  userId      Int
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Relations
  runs       PipelineRun[]
}

model PipelineRun {
  id         String   @id @default(cuid())
  pipelineId String
  pipeline   Pipeline @relation(fields: [pipelineId], references: [id], onDelete: Cascade)
  status     String   @default("pending")
  progress   Int      @default(0)
  result     String?  // JSON result
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model ContactSubmission {
  id          Int      @id @default(autoincrement())
  name        String
  email       String
  subject     String
  message     String
  createdAt   DateTime @default(now())
  status      String   @default("new")
  notes       String?
  metadata    String?
  assignedTo  String?
  budget      String?
  company     String?
  heardFrom   String?
  ipAddress   String?
  newsletter  Boolean? @default(false)
  phone       String?
  projectType String?
  timeline    String?
  userAgent   String?
}

model Component {
  id          String   @id @default(cuid())
  name        String
  description String?
  type        String   @default("ui")
  status      String   @default("draft")
  config      String?  // JSON configuration
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  userId      Int
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Todo {
  id          Int      @id @default(autoincrement())
  title       String
  description String?
  is_complete Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Role {
  id          Int      @id @default(autoincrement())
  name        String   @unique
  description String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  rolePermissions RolePermission[]
  userRoles       UserRole[]

  @@map("roles")
}

model Permission {
  id          Int      @id @default(autoincrement())
  name        String   @unique
  description String?
  resource    String   // e.g., "user", "bot", "model"
  action      String   // e.g., "create", "read", "update", "delete"
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  rolePermissions RolePermission[]

  @@map("permissions")
}

model RolePermission {
  id           Int        @id @default(autoincrement())
  roleId       Int
  permissionId Int
  createdAt    DateTime   @default(now())

  // Relations
  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([roleId, permissionId])
  @@map("role_permissions")
}

model UserRole {
  id          Int      @id @default(autoincrement())
  userId      Int
  roleId      Int
  assignedAt  DateTime @default(now())
  expiresAt   DateTime?
  isActive    Boolean  @default(true)
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  role        Role     @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([userId, roleId])
  @@map("user_roles")
}

// Dataset model for LLM training data
model Dataset {
  id          String   @id @default(cuid())
  name        String
  description String?
  type        String   // text-generation, text-classification, question-answering, summarization
  status      String   @default("uploading") // uploading, processing, ready, error
  size        Int      @default(0)
  format      String   // csv, json, txt, jsonl
  samples     Int?
  filePath    String?
  userId      Int?
  user        User?    @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([userId])
  @@index([status])
  @@index([type])
}
