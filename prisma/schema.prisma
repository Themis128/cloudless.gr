// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
  output   = "../node_modules/.prisma/client"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model ContactSubmission {
  id        Int      @id @default(autoincrement())
  name      String
  email     String
  subject   String
  message   String
  createdAt DateTime @default(now())
  // Status can be used to track if the submission has been read, replied to, etc.
  status    String   @default("new") // "new", "read", "replied", "archived"
  // Optional notes field for admins to add additional information
  notes     String?
  // Metadata field for storing submission details like IP, user agent, etc.
  metadata  String?
}
