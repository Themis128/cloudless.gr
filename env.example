# Cloudless.gr Environment Variables Template
# Copy this file to .env and fill in your values

# Application
NODE_ENV=development
APP_PORT=3000
APP_VERSION=1.0.0
LOG_LEVEL=info

# Supabase Configuration
NUXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NUXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Database Configuration
DATABASE_URL=postgresql://cloudless:password@localhost:5432/cloudless_dev?schema=public
POSTGRES_DB=cloudless_dev
POSTGRES_USER=cloudless
POSTGRES_PASSWORD=your-secure-password

# Redis Configuration
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=your-redis-password
REDIS_MAX_MEMORY=512mb

# External API Keys
OPENAI_API_KEY=sk-your-openai-key
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key

# Security
SESSION_SECRET=your-session-secret-min-32-chars
JWT_SECRET=your-jwt-secret-min-32-chars

# Monitoring (Production)
SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id
SENTRY_SECRET_KEY=your-sentry-secret
SENTRY_DB_PASSWORD=sentry-db-password

# Grafana (Production)
GRAFANA_USER=admin
GRAFANA_PASSWORD=your-secure-grafana-password

# Build Information (CI/CD)
GIT_COMMIT=unknown
BUILD_DATE=unknown

# Nginx Ports (Production)
NGINX_PORT=80
NGINX_SSL_PORT=443

# Backup Configuration (Production)
BACKUP_RETENTION_DAYS=7 