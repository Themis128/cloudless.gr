# Docker Environment Configuration for Cloudless LLM Dev Agent
# Copy this file to .env and fill in your actual values
# This file is specifically for Docker container deployments

# =============================================================================
# APPLICATION CONFIGURATION
# =============================================================================
NODE_ENV=production
NITRO_HOST=0.0.0.0
NITRO_PORT=3000
NUXT_HOST=0.0.0.0
NUXT_PORT=3000

# =============================================================================
# SUPABASE CONFIGURATION (REQUIRED FOR DOCKER)
# =============================================================================
# These MUST be set for Docker containers to connect to Supabase
NUXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NUXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# =============================================================================
# DOCKER NETWORK CONFIGURATION
# =============================================================================
# For external services (Supabase, Redis, etc.)
# Use host.docker.internal for Docker Desktop on Windows/Mac
# Use host IP address for Linux Docker hosts
EXTERNAL_HOST=host.docker.internal

# =============================================================================
# REDIS CONFIGURATION (Optional)
# =============================================================================
# For local Redis in Docker Compose
REDIS_URL=redis://redis-dev:6379
# For external Redis
# REDIS_URL=redis://your-redis-host:6379

# =============================================================================
# DATABASE CONFIGURATION (Optional - if using local PostgreSQL)
# =============================================================================
POSTGRES_DB=cloudless_dev
POSTGRES_USER=cloudless
POSTGRES_PASSWORD=development
DATABASE_URL=postgresql://cloudless:development@postgres-dev:5432/cloudless_dev

# =============================================================================
# DOCKER SPECIFIC SETTINGS
# =============================================================================
# Container identification
CONTAINER_NAME=cloudlessgr-app
IMAGE_TAG=latest

# Health check settings
HEALTH_CHECK_INTERVAL=30s
HEALTH_CHECK_TIMEOUT=10s
HEALTH_CHECK_RETRIES=3

# Logging
LOG_LEVEL=info
NITRO_LOG_LEVEL=info

# Performance
NODE_OPTIONS=--max-old-space-size=2048

# =============================================================================
# SECURITY (Production)
# =============================================================================
SESSION_SECRET=your-session-secret-here
JWT_SECRET=your-jwt-secret-here

# =============================================================================
# MONITORING
# =============================================================================
SENTRY_DSN=your-sentry-dsn

# =============================================================================
# APPLICATION METADATA
# =============================================================================
APP_VERSION=1.0.0
GIT_COMMIT=unknown
BUILD_DATE=unknown

# =============================================================================
# DOCKER DEBUGGING (Development only)
# =============================================================================
# Uncomment for debugging Docker container issues
# NITRO_DEBUG=1
# DEBUG=*
# NODE_OPTIONS=--trace-warnings --trace-uncaught 