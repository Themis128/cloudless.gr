# ──────────────────────────────────────────────────────────────────────────────
# cloudless.gr — environment variables template
#
# Copy to .env.local for local development. Production uses AWS SSM Parameter
# Store (path prefix /cloudless/production/) — see README.md § Secrets Management.
# ──────────────────────────────────────────────────────────────────────────────

# ── AWS ───────────────────────────────────────────────────────────────────────
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your-access-key-id
AWS_SECRET_ACCESS_KEY=your-secret-access-key

# ── Cognito ───────────────────────────────────────────────────────────────────
COGNITO_USER_POOL_ID=us-east-1_xxxxxxxxx
COGNITO_CLIENT_ID=your-cognito-client-id
NEXT_PUBLIC_COGNITO_USER_POOL_ID=us-east-1_xxxxxxxxx
NEXT_PUBLIC_COGNITO_CLIENT_ID=your-cognito-client-id

# ── SES (transactional email) ──────────────────────────────────────────────────
SES_FROM_EMAIL=hello@cloudless.gr
SES_TO_EMAIL=admin@cloudless.gr
AWS_SES_REGION=us-east-1

# ── Stripe ────────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# ── Slack ─────────────────────────────────────────────────────────────────────
SLACK_BOT_TOKEN=xoxb-...
SLACK_SIGNING_SECRET=your-slack-signing-secret
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/...

# ── HubSpot CRM ───────────────────────────────────────────────────────────────
HUBSPOT_API_KEY=your-hubspot-private-app-token

# ── Notion ────────────────────────────────────────────────────────────────────
NOTION_API_KEY=secret_...
NOTION_BLOG_DB_ID=your-blog-database-id
NOTION_SUBMISSIONS_DB_ID=your-submissions-database-id
NOTION_DOCS_DB_ID=your-docs-database-id
NOTION_PROJECTS_DB_ID=your-projects-database-id
NOTION_TASKS_DB_ID=your-tasks-database-id
NOTION_ANALYTICS_DB_ID=your-analytics-database-id
NOTION_WEBHOOK_SECRET=your-notion-webhook-secret

# ── Google (Calendar + Search Console) ────────────────────────────────────────
# Shared service account used for both Google Calendar and GSC.
GOOGLE_CLIENT_EMAIL=service-account@your-project.iam.gserviceaccount.com
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----"
GOOGLE_CALENDAR_ID=primary

# ── Ahrefs ────────────────────────────────────────────────────────────────────
AHREFS_API_KEY=your-ahrefs-api-key

# ── Sentry ────────────────────────────────────────────────────────────────────
SENTRY_AUTH_TOKEN=sntrys_...
SENTRY_ORG=baltzakisthemiscom
SENTRY_PROJECT=cloudless-gr
NEXT_PUBLIC_SENTRY_DSN=https://...@sentry.io/...

# ── App ───────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:4000
