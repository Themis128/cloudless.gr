# ──────────────────────────────────────────────────────────────
# All secrets are stored in AWS SSM Parameter Store (us-east-1)
# under the path prefix: /cloudless/production/
#
# The app fetches them at runtime via src/lib/ssm-config.ts.
# No secrets need to live in this file for production.
#
# SSM Parameters (production) — 25 params total:
#   /cloudless/production/AWS_SES_REGION           (String)
#   /cloudless/production/COGNITO_CLIENT_ID        (String)
#   /cloudless/production/COGNITO_USER_POOL_ID     (String)
#   /cloudless/production/GOOGLE_CLIENT_EMAIL      (String)
#   /cloudless/production/GOOGLE_PRIVATE_KEY       (SecureString)
#   /cloudless/production/GSC_SITE_URL             (String)
#   /cloudless/production/HUBSPOT_ACCESS_TOKEN     (SecureString)
#   /cloudless/production/HUBSPOT_API_KEY          (SecureString)
#   /cloudless/production/HUBSPOT_PORTAL_ID        (String)
#   /cloudless/production/NEWSLETTER_SEND_SECRET   (SecureString)
#   /cloudless/production/NEXT_PUBLIC_SENTRY_DSN   (String)
#   /cloudless/production/NOTION_ANALYTICS_DB_ID   (String)
#   /cloudless/production/NOTION_API_KEY           (SecureString)
#   /cloudless/production/NOTION_BLOG_DB_ID        (String)
#   /cloudless/production/NOTION_DOCS_DB_ID        (String)
#   /cloudless/production/NOTION_GSC_REPORTS_DB_ID (String)
#   /cloudless/production/NOTION_PROJECTS_DB_ID    (String)
#   /cloudless/production/NOTION_SUBMISSIONS_DB_ID (String)
#   /cloudless/production/NOTION_TASKS_DB_ID       (String)
#   /cloudless/production/NOTION_WEBHOOK_SECRET    (SecureString)
#   /cloudless/production/SENTRY_AUTH_TOKEN        (SecureString)
#   /cloudless/production/SENTRY_ORG               (String)
#   /cloudless/production/SENTRY_PROJECT           (String)
#   /cloudless/production/SES_FROM_EMAIL           (String)
#   /cloudless/production/SES_TO_EMAIL             (String)
#   /cloudless/production/SLACK_BOT_TOKEN          (SecureString)
#   /cloudless/production/SLACK_DEFAULT_CHANNEL    (String)
#   /cloudless/production/SLACK_SIGNING_SECRET     (SecureString)
#   /cloudless/production/SLACK_WEBHOOK_URL        (String)
#   /cloudless/production/STRIPE_PUBLISHABLE_KEY   (SecureString)
#   /cloudless/production/STRIPE_SECRET_KEY        (SecureString)
#   /cloudless/production/STRIPE_WEBHOOK_SECRET    (SecureString)
#
# LOCAL DEV:
#   Make sure your AWS CLI is configured (aws configure) with
#   credentials that have ssm:GetParametersByPath permission.
# ──────────────────────────────────────────────────────────────

# ── App ────────────────────────────────────────────────────────
APP_URL=http://localhost:3000

# ── Cognito (required — used client-side and server-side) ──────
NEXT_PUBLIC_COGNITO_USER_POOL_ID=us-east-1_JQWwFbO9a
NEXT_PUBLIC_COGNITO_CLIENT_ID=2qq6i24oc48391cmuv4kfl1rm2
# Server-side aliases (used by admin API routes and ssm-config.ts)
COGNITO_USER_POOL_ID=us-east-1_JQWwFbO9a
COGNITO_CLIENT_ID=2qq6i24oc48391cmuv4kfl1rm2

# ── HubSpot ────────────────────────────────────────────────────
# Tracking code (client-side, safe)
NEXT_PUBLIC_HUBSPOT_PORTAL_ID=147639927
# API key — for local dev only; prod uses SSM at /cloudless/production/HUBSPOT_API_KEY
# Create a Private App at: Settings > Integrations > Private Apps
# Scopes needed: crm.objects.contacts (r/w), crm.objects.deals (r/w)
# HUBSPOT_API_KEY=pat-eu1-xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# ── Notion ─────────────────────────────────────────────────────
# 1. Go to https://www.notion.so/my-integrations → Create integration
# 2. Copy the "Internal Integration Secret" below
# 3. Share each database with your integration (DB → … → Connections)
NOTION_API_KEY=secret_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Database IDs (from Notion workspace URLs)
NOTION_BLOG_DB_ID=0ac591657ee44063bbbc8004ea7ccd6c
NOTION_SUBMISSIONS_DB_ID=9abe0a5614d64b759d44a45cee2d0bbc
NOTION_DOCS_DB_ID=b45af6ed5bb64d89b9a92a8aff4a9b29
NOTION_PROJECTS_DB_ID=a9bab34b945e484fb6b0aa6034086e5c
NOTION_TASKS_DB_ID=14ce4ff6c400437597b13e70ac909354
NOTION_ANALYTICS_DB_ID=cc4287fcb42a42dc92a7053d6f1199c7
NOTION_GSC_REPORTS_DB_ID=33212a36f3f74649a7702dd8b26e7945

# Webhook secret — authenticate incoming calls to /api/webhooks/notion
# Generate with: openssl rand -hex 32
NOTION_WEBHOOK_SECRET=your_random_secret_here

# ── Slack ──────────────────────────────────────────────────────
# App dashboard: https://api.slack.com/apps/A0ARP8UGQLB
# SLACK_BOT_TOKEN      → OAuth & Permissions → Bot User OAuth Token (xoxb-...)
# SLACK_SIGNING_SECRET → Basic Information → App Credentials → Signing Secret
# SLACK_WEBHOOK_URL    → Incoming Webhooks → Webhook URL
SLACK_BOT_TOKEN=xoxb-xxxxxxxxxxxx-xxxxxxxxxxxx-xxxxxxxxxxxxxxxxxxxxxxxx
SLACK_SIGNING_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/XXXXXXXXX/XXXXXXXXXX/xxxxxxxxxxxxxxxxxxxxxxxx
SLACK_DEFAULT_CHANNEL=general

# ── Sentry ─────────────────────────────────────────────────────
# 1. Go to https://sentry.io → Settings → Auth Tokens → Create New Token
# 2. Select scopes: project:read, project:write, org:read
# Token starts with sntrys_...
# Org slug: cloudless  |  Project slug: cloudless-gr  (already defaulted in code)
# SENTRY_AUTH_TOKEN=sntrys_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# DSN for the @sentry/nextjs SDK — public, safe to commit to version control.
# Find it at: Sentry → cloudless-gr project → Settings → Client Keys (DSN)
# NEXT_PUBLIC_SENTRY_DSN=https://xxxx@oxxxxxx.ingest.sentry.io/xxxxxx

# ── AWS SES (Email) ────────────────────────────────────────────
# Production uses SSM; these defaults work for local dev.
SES_FROM_EMAIL=noreply@cloudless.gr
SES_TO_EMAIL=tbaltzakis@cloudless.gr
AWS_SES_REGION=us-east-1
AWS_REGION=us-east-1

# ── Stripe ─────────────────────────────────────────────────────
# Production uses SSM; for local dev use test-mode keys from:
#   https://dashboard.stripe.com/test/apikeys
# Webhook secret: stripe listen --forward-to localhost:3000/api/webhooks/stripe
# STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# STRIPE_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Google Service Account (GSC + Calendar) ────────────────────
# Service account for Google Search Console and Google Calendar API access.
# 1. Create a service account at https://console.cloud.google.com/iam-admin/serviceaccounts
# 2. Enable Search Console API + Google Calendar API
# 3. Download the JSON key and extract client_email and private_key below
# 4. Add the service account email as a "Full" user in GSC property settings
GSC_SITE_URL=sc-domain:cloudless.gr
GOOGLE_CLIENT_EMAIL=your-service-account@your-project.iam.gserviceaccount.com
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# Google Calendar ID — share a calendar with the service account email above,
# then paste the Calendar ID here (Calendar Settings → Integrate calendar → Calendar ID)
# Defaults to "primary" (service account's own calendar) if not set.
# GOOGLE_CALENDAR_ID=your-calendar-id@group.calendar.google.com

# ── Sentry Org & Project (used by @sentry/nextjs plugin and source maps) ──
SENTRY_ORG=baltzakisthemiscom
SENTRY_PROJECT=cloudless-gr
NEXT_PUBLIC_SENTRY_ORG=baltzakisthemiscom

# ── Ahrefs (optional — for backlink/keyword data) ─────────────
# AHREFS_API_KEY=your_ahrefs_api_key_here
