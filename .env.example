# For Production/Cloud Supabase (Replace with your actual values)
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ========================================
# APPLICATION CONFIGURATION
# ========================================
NUXT_PUBLIC_SITE_URL=http://localhost:3000
NODE_ENV=development
PORT=3000

# ========================================
# SECURITY KEYS
# ========================================
JWT_SECRET=eOvlpJPRGfQkptMLRFSfCPerPR5MkrekkpIuLqXd
JWT_REFRESH_SECRET=your_jwt_refresh_secret_here
API_SECRET_KEY=your_api_secret_key_here
SESSION_SECRET=your_session_secret_here

# ========================================
# AI CONFIGURATION (Ollama)
# ========================================

# Host where Ollama is running (default: http://localhost:11434)
OLLAMA_HOST=http://localhost:11434

# Ollama model to use for description generation
# Popular options: llama3.2:latest, llama3.1:latest, codellama:latest, mistral:latest
OLLAMA_MODEL=llama3.2:latest

# ========================================
# OPTIONAL: EMAIL CONFIGURATION
# ========================================
# SMTP_HOST=your-smtp-host
# SMTP_PORT=587
# SMTP_USER=your-smtp-user
# SMTP_PASS=your-smtp-password
