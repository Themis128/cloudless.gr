# Example environment variables for LLM integration
LLM_API_URL=http://localhost:11434/api/generate
LLM_MODEL=phind-codellama:34b

# Auth0 Configuration
NUXT_AUTH0_DOMAIN=your-auth0-domain.auth0.com
NUXT_AUTH0_CLIENT_ID=your-auth0-client-id
NUXT_AUTH0_AUDIENCE=your-auth0-audience

# Public URL for redirects
NUXT_PUBLIC_URL=http://localhost:3000

# MinIO Configuration
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_USE_SSL=false
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin

# Supabase Configuration (REQUIRED)
# Get these from your Supabase project dashboard at https://supabase.com/dashboard
NUXT_SUPABASE_URL=https://your-project-ref.supabase.co
NUXT_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_KEY=your_supabase_service_key

# JWT Secret (for session management)
NUXT_JWT_SECRET=your-random-jwt-secret-key

# Admin credentials (for development only, use secure authentication in production)
ADMIN_EMAIL=admin@cloudless.gr
ADMIN_PASSWORD=cloudless2025

# Stripe Configuration (REQUIRED for billing features)
STRIPE_PUBLISHABLE_KEY=pk_test_your_publishable_key
STRIPE_SECRET_KEY=sk_test_your_secret_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# Stripe Product IDs (create these in Stripe Dashboard)
STRIPE_STARTER_PRICE_ID=price_starter_monthly
STRIPE_PRO_PRICE_ID=price_pro_monthly
STRIPE_BUSINESS_PRICE_ID=price_business_monthly
