{
  "mcpServers": {
    "project": {
      "command": "npx",
      "args": [
        "-y",
        "project-mcp"
      ],
      "autoStart": true
    },
    "mcp-tool-shop": {
      "command": "npx",
      "args": [
        "-y",
        "mcp-tool-shop"
      ],
      "autoStart": true
    },
    "notion": {
      "command": "npx",
      "args": [
        "-y",
        "@notionhq/notion-mcp-server"
      ],
      "env": {
        "OPENAPI_MCP_HEADERS": "{\"Authorization\":\"Bearer ${NOTION_API_KEY}\",\"Notion-Version\":\"2022-06-28\"}"
      },
      "autoStart": true
    }
  }
}
