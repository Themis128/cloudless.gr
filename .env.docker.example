# Environment variables for Docker development
# Copy this file to .env.docker and customize values

# Application
NODE_ENV=development
NUXT_HOST=0.0.0.0
NUXT_PORT=3000

# Auth0 Configuration
NUXT_AUTH0_DOMAIN=your-auth0-domain.auth0.com
NUXT_AUTH0_CLIENT_ID=your-auth0-client-id
NUXT_AUTH0_AUDIENCE=your-auth0-audience

# Supabase Configuration
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_KEY=your-supabase-service-key

# JWT Secret (generate a secure random string)
NUXT_JWT_SECRET=your-jwt-secret-key

# Admin Configuration
ADMIN_EMAIL=admin@cloudless.gr

# MinIO Configuration
MINIO_ENDPOINT=minio
MINIO_PORT=9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_USE_SSL=false

# PostgreSQL Configuration (if using)
POSTGRES_DB=cloudless_dev
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# Public URL (for production)
NUXT_PUBLIC_URL=http://localhost:3000
