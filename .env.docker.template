# Docker Environment Configuration Template
# Copy this file to .env.docker and update with your actual values

# ============================================================================
# CORE APPLICATION SETTINGS
# ============================================================================
NODE_ENV=production
NUXT_HOST=0.0.0.0
NUXT_PORT=3000

# ============================================================================
# SUPABASE CONFIGURATION (REQUIRED)
# ============================================================================
# Get these values from your Supabase dashboard > Settings > API
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_KEY=your-service-role-key-here

# Alternative environment variable names for compatibility
NUXT_SUPABASE_URL=https://your-project-ref.supabase.co
NUXT_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_KEY=your-anon-key-here

# ============================================================================
# AUTHENTICATION & SECURITY
# ============================================================================
# Generate strong secrets for production
NUXT_JWT_SECRET=your-very-long-secure-jwt-secret-here-minimum-32-characters
NUXT_AUTH_SECRET=your-very-long-secure-auth-secret-here-minimum-32-characters

# Auth0 Configuration (if using Auth0)
NUXT_AUTH0_DOMAIN=your-domain.auth0.com
NUXT_AUTH0_CLIENT_ID=your-auth0-client-id
NUXT_AUTH0_AUDIENCE=https://your-api-audience

# Admin Credentials
ADMIN_EMAIL=admin@yourdomain.com
ADMIN_PASSWORD=your-secure-admin-password

# Application URL
AUTH_ORIGIN=https://yourdomain.com

# ============================================================================
# DATABASE CONFIGURATION
# ============================================================================
# PostgreSQL (if using local database)
POSTGRES_DB=cloudless_prod
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your-secure-postgres-password

# Database URL for applications
DATABASE_URL=postgresql://postgres:your-secure-postgres-password@postgres:5432/cloudless_prod

# ============================================================================
# MINIO / S3 STORAGE CONFIGURATION
# ============================================================================
MINIO_ENDPOINT=minio
MINIO_PORT=9000
MINIO_ACCESS_KEY=your-minio-access-key
MINIO_SECRET_KEY=your-minio-secret-key
MINIO_USE_SSL=false

# ============================================================================
# API & INTEGRATIONS
# ============================================================================
# LLM Configuration
LLM_API_URL=http://localhost:11434/api/generate
LLM_MODEL=phind-codellama:34b

# API Keys for external services
API_KEY=your-api-key-here

# ============================================================================
# DEPLOYMENT SPECIFIC
# ============================================================================
# Public URL for your deployment
NUXT_PUBLIC_URL=https://yourdomain.com

# Environment identifier
ENVIRONMENT=production

# ============================================================================
# MONITORING & LOGGING
# ============================================================================
PORTAINER_LOG_LEVEL=INFO

