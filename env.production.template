# Production Environment Variables Template for Cloudless.gr
# Copy this file to .env.production and fill in your actual values
# This template includes the latest security and performance configurations

# =============================================================================
# APPLICATION CONFIGURATION
# =============================================================================
NODE_ENV=production
NITRO_HOST=0.0.0.0
NITRO_PORT=3000
NUXT_HOST=0.0.0.0
NUXT_PORT=3000

# Performance Optimizations
NITRO_PRESET=node
NITRO_COMPRESSION=true
NITRO_MINIFY=true
NODE_OPTIONS=--max-old-space-size=2048 --enable-source-maps

# =============================================================================
# SUPABASE CONFIGURATION
# =============================================================================
# Replace with your actual Supabase project URL
NUXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
# Replace with your actual Supabase anonymous key
NUXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
# Replace with your actual Supabase service role key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# =============================================================================
# DATABASE CONFIGURATION
# =============================================================================
# PostgreSQL connection string
DATABASE_URL=postgresql://cloudless:your-password@postgres:5432/cloudless_prod
POSTGRES_DB=cloudless_prod
POSTGRES_USER=cloudless
POSTGRES_PASSWORD=your-secure-password-here

# =============================================================================
# REDIS CONFIGURATION
# =============================================================================
# Redis connection string
REDIS_URL=redis://redis:6379
REDIS_PASSWORD=your-secure-redis-password
REDIS_MAX_MEMORY=512mb

# =============================================================================
# EXTERNAL API KEYS
# =============================================================================
# Replace with your actual API keys
OPENAI_API_KEY=your-openai-api-key-here
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# =============================================================================
# SECURITY
# =============================================================================
# Generate secure random strings for production
SESSION_SECRET=your-super-secure-session-secret-here
JWT_SECRET=your-super-secure-jwt-secret-here

# =============================================================================
# MONITORING AND LOGGING
# =============================================================================
# Replace with your actual Sentry DSN
SENTRY_DSN=your-sentry-dsn-here
LOG_LEVEL=info

# =============================================================================
# DOCKER CONFIGURATION
# =============================================================================
# For production deployments
DOCKER_REGISTRY=ghcr.io
IMAGE_TAG=latest
APP_PORT=3000

# =============================================================================
# NGINX CONFIGURATION
# =============================================================================
NGINX_PORT=80
NGINX_SSL_PORT=443

# =============================================================================
# APPLICATION METADATA
# =============================================================================
APP_VERSION=1.0.0
GIT_COMMIT=unknown
BUILD_DATE=unknown

# =============================================================================
# MONITORING AND OBSERVABILITY
# =============================================================================
# Grafana admin password
GRAFANA_PASSWORD=your-secure-grafana-password

# Prometheus configuration
PROMETHEUS_RETENTION_DAYS=30

# =============================================================================
# BACKUP CONFIGURATION
# =============================================================================
# Database backup retention (days)
BACKUP_RETENTION_DAYS=7

# =============================================================================
# SECURITY HEADERS
# =============================================================================
# Disable Nuxt telemetry
NUXT_TELEMETRY_DISABLED=1

# =============================================================================
# PERFORMANCE TUNING
# =============================================================================
# Node.js performance settings
NODE_OPTIONS=--max-old-space-size=2048 --enable-source-maps --optimize-for-size

# =============================================================================
# ENVIRONMENT SPECIFIC
# =============================================================================
# Set to 'true' to enable monitoring profile
ENABLE_MONITORING=false

# Set to 'true' to enable backup profile
ENABLE_BACKUP=false

# =============================================================================
# SSL/TLS CONFIGURATION (if using Let's Encrypt)
# =============================================================================
# Let's Encrypt email for SSL certificates
LETSENCRYPT_EMAIL=your-email@domain.com

# Domain name for SSL certificates
DOMAIN_NAME=your-domain.com

# =============================================================================
# RATE LIMITING
# =============================================================================
# Rate limiting configuration
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# =============================================================================
# CACHE CONFIGURATION
# =============================================================================
# Cache TTL settings
CACHE_TTL=3600
REDIS_CACHE_TTL=1800

# =============================================================================
# FILE UPLOAD CONFIGURATION
# =============================================================================
# Maximum file upload size (in bytes)
MAX_FILE_SIZE=10485760

# Allowed file types
ALLOWED_FILE_TYPES=image/jpeg,image/png,image/gif,application/pdf,text/plain

# =============================================================================
# EMAIL CONFIGURATION (if using SMTP)
# =============================================================================
# SMTP configuration for email sending
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM=noreply@your-domain.com

# =============================================================================
# CDN CONFIGURATION (if using CDN)
# =============================================================================
# CDN URL for static assets
CDN_URL=https://cdn.your-domain.com

# =============================================================================
# ANALYTICS CONFIGURATION
# =============================================================================
# Google Analytics ID
GA_ID=G-XXXXXXXXXX

# =============================================================================
# FEATURE FLAGS
# =============================================================================
# Enable/disable features
ENABLE_ANALYTICS=true
ENABLE_NOTIFICATIONS=true
ENABLE_FILE_UPLOAD=true
ENABLE_USER_REGISTRATION=true

# =============================================================================
# MAINTENANCE MODE
# =============================================================================
# Set to 'true' to enable maintenance mode
MAINTENANCE_MODE=false
MAINTENANCE_MESSAGE=We are currently performing maintenance. Please check back soon.

# =============================================================================
# DEBUGGING (disable in production)
# =============================================================================
# Set to 'true' only for debugging (disable in production)
DEBUG=false
NITRO_DEBUG=false 