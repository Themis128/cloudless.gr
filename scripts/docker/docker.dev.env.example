# Development Environment Configuration for Cloudless LLM Dev Agent
# Copy this file to .env and fill in your actual values
# This file is specifically for Docker development containers

# =============================================================================
# APPLICATION CONFIGURATION
# =============================================================================
NODE_ENV=development
NITRO_HOST=0.0.0.0
NITRO_PORT=3000
NUXT_HOST=0.0.0.0
NUXT_PORT=3000

# =============================================================================
# SUPABASE CONFIGURATION (REQUIRED FOR DEVELOPMENT)
# =============================================================================
# These MUST be set for development containers to connect to Supabase
NUXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NUXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# =============================================================================
# DEVELOPMENT TOOLS
# =============================================================================
# Hot reloading and file watching
CHOKIDAR_USEPOLLING=true
WATCHPACK_POLLING=true

# Debugging
NITRO_DEBUG=1
DEBUG=*
NODE_OPTIONS=--inspect=0.0.0.0:9229 --max-old-space-size=4096

# Development server settings
NITRO_LOG_LEVEL=debug
NUXT_DEVTOOLS=true

# =============================================================================
# DOCKER DEVELOPMENT NETWORK
# =============================================================================
# For external services (Supabase, Redis, etc.)
# Use host.docker.internal for Docker Desktop on Windows/Mac
# Use host IP address for Linux Docker hosts
EXTERNAL_HOST=host.docker.internal

# =============================================================================
# REDIS CONFIGURATION (Development)
# =============================================================================
# For local Redis in Docker Compose development
REDIS_URL=redis://redis-dev:6379
REDIS_PASSWORD=development

# =============================================================================
# DATABASE CONFIGURATION (Development - Optional)
# =============================================================================
# For local PostgreSQL in Docker Compose development
POSTGRES_DB=cloudless_dev
POSTGRES_USER=cloudless
POSTGRES_PASSWORD=development
DATABASE_URL=postgresql://cloudless:development@postgres-dev:5432/cloudless_dev

# =============================================================================
# DEVELOPMENT TOOLS CONFIGURATION
# =============================================================================
# Redis Commander (Development Tool)
REDIS_COMMANDER_USER=admin
REDIS_COMMANDER_PASSWORD=admin

# Mailhog for email testing (Development)
MAILHOG_SMTP_PORT=1025
MAILHOG_WEB_PORT=8025

# Adminer for database management (Development)
ADMINER_PORT=8080

# =============================================================================
# EXTERNAL API KEYS (Development)
# =============================================================================
# Use development/test keys for development environment
OPENAI_API_KEY=your-openai-dev-key
ANTHROPIC_API_KEY=your-anthropic-dev-key

# =============================================================================
# MONITORING AND LOGGING (Development)
# =============================================================================
SENTRY_DSN=your-sentry-dev-dsn
LOG_LEVEL=debug

# =============================================================================
# SECURITY (Development)
# =============================================================================
# Use development secrets (not production secrets)
SESSION_SECRET=dev-session-secret-here
JWT_SECRET=dev-jwt-secret-here

# =============================================================================
# DOCKER DEVELOPMENT SETTINGS
# =============================================================================
# Container identification
CONTAINER_NAME=cloudlessgr-app-dev
IMAGE_TAG=dev

# Health check settings (more frequent for development)
HEALTH_CHECK_INTERVAL=10s
HEALTH_CHECK_TIMEOUT=5s
HEALTH_CHECK_RETRIES=5

# Development features
STDIN_OPEN=true
TTY=true

# =============================================================================
# TIMEZONE AND LOCALE
# =============================================================================
TZ=Europe/Athens
LANG=en_US.UTF-8
LC_ALL=en_US.UTF-8

# =============================================================================
# APPLICATION METADATA
# =============================================================================
APP_VERSION=1.0.0-dev
GIT_COMMIT=unknown
BUILD_DATE=unknown

# =============================================================================
# DEVELOPMENT DEBUGGING
# =============================================================================
# Uncomment for enhanced debugging
# NITRO_DEBUG=1
# DEBUG=*
# NODE_OPTIONS=--trace-warnings --trace-uncaught --inspect-brk=0.0.0.0:9229

# =============================================================================
# DEVELOPMENT PROFILES
# =============================================================================
# Uncomment to enable specific development profiles
# PROFILE=database    # Enable local PostgreSQL
# PROFILE=email       # Enable Mailhog
# PROFILE=redis       # Enable Redis Commander 