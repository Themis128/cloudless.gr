{
    "suggestionLanguage": "en",
    "enableCompletions": true,
    "enableCopilot": true,
    "inlineSuggest.enable": true,
    "advanced": {
        "enableTabCompletion": true,
        "enableAutoCompletions": true
    },
    "fileTypes": [
        ".js",
        ".ts",
        ".vue",
        ".json",
        ".md",
        ".css",
        ".scss",
        ".yml",
        ".yaml",
        ".env",
        ".sql",
        ".sh"
    ],
    "exclude": [
        "node_modules/",
        ".nuxt/",
        ".output/",
        ".git/",
        "dist/",
        "build/",
        
        ".vscode/",
        "coverage/",
        "logs/",
        "tmp/",
        ".DS_Store"
    ],
    "maxSuggestions": 10,
    "enableCopilotChat": true,
    "enableInlayHints": true
}